---
import AppStoreAppPage from "../../components/apps/AppStoreAppPage.astro";
import { DEFAULT_LOCALE } from "../../i18n/config";
import { getTranslations } from "../../i18n/utils";
import { getAppStoreAppStaticParams, type AppStoreAppItem } from "../../lib/app-store-detail";

export function getStaticPaths() {
  return getAppStoreAppStaticParams();
}

const { app } = Astro.props as { app: AppStoreAppItem };
const translations = getTranslations(DEFAULT_LOCALE);
---

<AppStoreAppPage app={app} lang={DEFAULT_LOCALE} translations={translations} />
