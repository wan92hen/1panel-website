---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Statistics from "../components/Statistics.astro";
import { Icon } from 'astro-icon/components'
import {
  SITE_URL,
  createBreadcrumbSchema,
  toAbsoluteUrl,
} from "../lib/seo";
import "../styles/global.css";

const siteUrl = Astro.site?.toString() ?? SITE_URL;
const openClawPageUrl = toAbsoluteUrl("/openclaw.html", siteUrl);
const openClawProductSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": `${openClawPageUrl}#product`,
  name: "OpenClaw 一体机",
  description:
    "OpenClaw 一体机面向团队和部门级 AI 部署场景，结合 1Panel 运维面板、本地模型能力与 FusionXpark 硬件，支持数据不出域的本地 AI 部署。",
  image: toAbsoluteUrl("/images/fusionxpark.png", siteUrl),
  brand: {
    "@type": "Brand",
    name: "FIT2CLOUD 飞致云",
  },
  url: openClawPageUrl,
};
---

<Layout
  title="OpenClaw 一体机 - 团队级本地 AI 部署方案"
  socialTitle="OpenClaw 一体机 - 1Panel 团队级本地 AI 部署方案"
  schemaName="OpenClaw 一体机"
  description="OpenClaw 一体机面向团队和部门级 AI 部署场景，结合 1Panel 运维面板、本地模型能力与 FusionXpark 硬件，实现数据不出域、隐私与性能兼得。"
  canonical="/openclaw.html"
  image="/images/fusionxpark.png"
  imageAlt="OpenClaw 一体机产品示意图"
  keywords={[
    "OpenClaw 一体机",
    "OpenClaw",
    "1Panel",
    "AI 一体机",
    "本地部署 AI",
    "本地 AI 部署",
    "私有化 AI 部署",
    "团队级 AI 部署",
    "FusionXpark",
    "1Panel AI",
  ]}
  structuredData={[
    createBreadcrumbSchema([
      { name: "1Panel 官网", url: toAbsoluteUrl("/", siteUrl) },
      { name: "OpenClaw 一体机", url: openClawPageUrl },
    ]),
    openClawProductSchema,
  ]}
>
  <Statistics slot="head" />
  <Fragment slot="main">
    <Header />
    <main class="relative z-10">
    <!-- Hero：左右布局，与首页一致，右侧展示 FusionXpark 图片 -->
    <section id="heroSection" class="relative min-h-[80vh] flex items-center overflow-hidden bg-gray-50">
      <!-- 浮动装饰（与 Hero.astro 一致） -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-20 left-10 w-20 h-20 rounded-full blur-2xl animate-float bg-1panel opacity-20"></div>
        <div class="absolute top-40 right-20 w-32 h-32 rounded-full blur-2xl animate-float bg-1panel opacity-30" style="animation-delay: -2s;"></div>
        <div class="absolute bottom-20 left-20 w-24 h-24 rounded-full blur-2xl animate-float bg-1panel opacity-40" style="animation-delay: -4s;"></div>
        <div class="absolute bottom-40 right-10 w-16 h-16 rounded-full blur-2xl animate-float bg-1panel opacity-60" style="animation-delay: -6s;"></div>
      </div>

      <div class="relative z-10 container-custom py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
          <!-- 左侧：文案 -->
          <div class="text-center lg:text-left">
            <div class="fade-in-up inline-flex items-center px-4 py-2 mb-6 bg-blue-100 text-blue-800 rounded-full text-sm font-medium">
              给员工一只虾 🦞，给虾一个家 🏡
            </div>
            <h1 class="fade-in-up text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-8" style="animation-delay: 0.2s;">
              <span class="block text-gray-800 mb-4" style="font-size:42px">OpenClaw 一体机</span>
              <span class="block text-1panel-gradient mb-2 leading-light">为团队部署而生</span>
            </h1>
            <p class="fade-in-up text-xl sm:text-2xl text-gray-500 mb-10 leading-relaxed" style="animation-delay: 0.4s;">
              轻松驾驭 10–20 个 AI 助理并行工作，彻底告别 Token 焦虑
            </p>
            <div class="fade-in-up flex gap-4 justify-center lg:justify-start" style="animation-delay: 0.5s;">
              <a href="https://jsj.top/f/UFPJsq" target="_blank" class="btn-primary text-lg px-8 py-4 inline-flex items-center justify-center">
                预约演示
              </a>
              <a href="https://www.bilibili.com/video/BV1scwxzvEsv/" target="_blank" class="btn-secondary text-lg px-8 py-4 inline-flex items-center justify-center">
                观看视频
              </a>
            </div>
          </div>
          <!-- 右侧：FusionXpark 产品图 -->
          <div class="fade-in-up flex justify-center lg:justify-end" style="animation-delay: 0.3s;">
            <div class="w-full max-w-lg">
              <img
                src="/images/fusionxpark.png"
                alt="FusionXpark OpenClaw 一体机"
                class="w-full h-auto"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 一站式配齐、深度优化：管知智模 + 硬件底座 -->
    <section class="section-padding bg-gradient-to-b from-gray-50 to-white">
      <div class="container-custom">
        <div class="soft-hard-section rounded-3xl bg-white border border-gray-100 shadow-sm shadow-gray-200/60 overflow-hidden">
          <!-- 标题区 -->
          <div class="px-6 sm:px-10 pt-10 pb-8 text-center border-b border-gray-100">
            <h2 class="section-title text-4xl lg:text-5xl font-bold text-gray-800 mb-6">一站式配齐、<span class="text-1panel-gradient">深度优化</span></h2>
            <p class="section-subtitle text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">成本可控，数据不出域，隐私与性能兼得，OpenClaw 部署的终极保险箱</p>
          </div>

          <!-- 上层：管知智模 四卡片 -->
          <div class="p-6 sm:p-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
              <div class="soft-hard-card rounded-xl bg-gray-50/80 border border-gray-100 p-5 transition-all duration-200 hover:border-indigo-100 hover:shadow-md">
                <div class="w-11 h-11 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600 font-bold text-base mb-3">管</div>
                <h3 class="text-base font-bold text-gray-900 mb-1.5">1Panel 运维面板</h3>
                <p class="text-sm text-gray-600 leading-relaxed">1Panel 提供直观易用的 Web 管理界面，让用户轻松部署和管理 AI 智能体和模型。</p>
              </div>
              <div class="soft-hard-card rounded-xl bg-gray-50/80 border border-gray-100 p-5 transition-all duration-200 hover:border-indigo-100 hover:shadow-md">
                <div class="w-11 h-11 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600 font-bold text-base mb-3">模</div>
                <h3 class="text-base font-bold text-gray-900 mb-1.5">本地 AI 模型</h3>
                <p class="text-sm text-gray-600 leading-relaxed">基于 vLLM 运行 Qwen3.6-35B-A3B-FP8 多模态模型，智能密度高，并发效率高。</p>
              </div>
              <div class="soft-hard-card rounded-xl bg-gray-50/80 border border-gray-100 p-5 transition-all duration-200 hover:border-indigo-100 hover:shadow-md">
                <div class="w-11 h-11 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600 font-bold text-base mb-3">智</div>
                <h3 class="text-base font-bold text-gray-900 mb-1.5">能做事的 AI 助理</h3>
                <p class="text-sm text-gray-600 leading-relaxed">支持 OpenClaw、Hermes 和 QwenPaw 多实例同时运行，支持对接国内主流聊天软件，内置常用 Skills。</p>
              </div>
              <div class="soft-hard-card rounded-xl bg-gray-50/80 border border-gray-100 p-5 transition-all duration-200 hover:border-indigo-100 hover:shadow-md">
                <div class="w-11 h-11 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600 font-bold text-base mb-3">知</div>
                <h3 class="text-base font-bold text-gray-900 mb-1.5">MaxKB AI 知识库（可选）</h3>
                <p class="text-sm text-gray-600 leading-relaxed">高效构建部门专属AI知识库，支持多种格式的文档导入，支持文本自动拆分和向量化。</p>
              </div>
            </div>

            <!-- 底座：硬件 -->
            <div class="mt-6 rounded-xl bg-gradient-to-r from-gray-50 to-indigo-50/40 border border-gray-100 border-t-2 border-t-indigo-200 p-5 flex flex-col sm:flex-row sm:items-center gap-4">
              <div class="w-12 h-12 rounded-lg bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-lg shrink-0">硬</div>
              <div class="min-w-0">
                <h3 class="text-base font-bold text-gray-900 mb-1">FusionXpark 硬件</h3>
                <p class="text-sm text-gray-600">巴掌大小的 AI 超算：128GB 统一内存、NVIDIA Blackwell GB10、1 PFLOPS 算力、2TB 存储，1.2kg，办公桌即放即用的工作站。</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 为什么要选择我？ -->
    <section class="section-padding bg-white border-t border-gray-100">
      <div class="container-custom">
        <div class="text-center mb-12">
          <h2 class="section-title text-4xl lg:text-5xl font-bold text-gray-800 mb-6">为什么要选择我？</h2>
          <p class="section-subtitle text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">不止于"可用"与"能用"，专为团队打造真正<span class="text-1panel-gradient font-bold ">"好用"</span>的 AI 一体机</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
          <!-- 强大性能 -->
          <div class="rounded-2xl bg-gray-100/80 border border-gray-100 p-6 lg:p-8 transition-all duration-200 hover:border-indigo-100 hover:shadow-md flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600 font-bold text-sm">✓</span>
              <h3 class="text-lg font-bold text-gray-900">强大性能，高并发无压力</h3>
            </div>
            <p class="text-gray-600 leading-relaxed flex-1">实测：GB10 芯片在 FP4 精度下，并发推理性能 ≈ 3 张 L20 / RTX 5880，轻松承载大模型任务，彻底告别 Token 焦虑。</p>
          </div>
          <!-- 简单易用 -->
          <div class="rounded-2xl bg-gray-100/80 border border-gray-100 p-6 lg:p-8 transition-all duration-200 hover:border-indigo-100 hover:shadow-md flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600 font-bold text-sm">✓</span>
              <h3 class="text-lg font-bold text-gray-900">简单易用，零门槛上手</h3>
            </div>
            <p class="text-gray-600 leading-relaxed flex-1">图形化界面，三步极速部署，无缝覆盖 Day 0 配置 → Day 1 管理 → Day 2 维护全周期。无需命令行，非技术成员也能高效运维，释放团队专注力。</p>
          </div>
          <!-- 安全可靠 -->
          <div class="rounded-2xl bg-gray-100/80 border border-gray-100 p-6 lg:p-8 transition-all duration-200 hover:border-indigo-100 hover:shadow-md flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600 font-bold text-sm">✓</span>
              <h3 class="text-lg font-bold text-gray-900">安全可靠，数据私有可控</h3>
            </div>
            <div class="text-gray-600 leading-relaxed flex-1 space-y-1">
              <p>独立沙箱环境，与办公电脑物理隔离，防止风险扩散。所有数据本地存储于一体机，信息不出域，保障隐私。内置访问来源管控、防火墙与 SSL 加密，支持密码和 Token 双重认证，全方位守护系统安全。</p>
            </div>
          </div>
          <!-- 全程陪伴 -->
          <div class="rounded-2xl bg-gray-100/80 border border-gray-100 p-6 lg:p-8 transition-all duration-200 hover:border-indigo-100 hover:shadow-md flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600 font-bold text-sm">✓</span>
              <h3 class="text-lg font-bold text-gray-900">全程陪伴，持续赋能</h3>
            </div>
            <p class="text-gray-600 leading-relaxed flex-1">深度融入 1Panel 开源生态，持续分享精选行业案例、实用调优指南与即用型实战模板，并配备工作日 5×8 小时线上专属交流群，全程陪伴您的 AI 应用落地之旅，做您可靠而温暖的同行伙伴。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 限时优惠横向布局（硬件、软件、服务） -->
    <section class="section-padding bg-white" id="pricing">
      <div class="container-custom">
        <div class="text-center mb-16">
          <h2 class="section-title text-4xl lg:text-5xl font-bold text-gray-800 mb-6"><span class="text-1panel-gradient">一体机价格</span></h2>
          <p class="section-subtitle text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
            <span class="font-semibold text-gray-800">飞致云</span> 联合 <span class="font-semibold text-gray-800">超聚变</span> 为用户带来专属限时优惠
          </p>
        </div>

        <!-- 横向三栏：硬件 软件 服务 -->
        <div class="flex flex-col md:flex-row md:justify-between gap-6 mb-12">
          <!-- 硬件 -->
          <div class="flex-1 flex flex-col items-center text-center rounded-2xl border-2 border-indigo-100 bg-white p-6 shadow hover:border-indigo-200 transition min-w-[220px]">
            <div class="w-14 h-14 mb-4 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600 font-bold text-xl">硬件</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">FusionXpark™ GB 10</h3>
            <p class="text-sm text-gray-500 mb-1">巴掌大小的 AI 超算，仅 1.2kg</p>
            <p class="text-sm text-gray-500">128GB 统一内存、2TB 存储</p>
            <p class="text-sm text-gray-500">NVIDIA Grace Blackwell GB10，1 PFLOPS 算力</p>
            <p class="text-xs text-gray-400 mt-2">* 含一年硬件保修</p>
          </div>
          <!-- 软件 -->
          <div class="flex-1 flex flex-col items-center text-center rounded-2xl border-2 border-indigo-100 bg-white p-6 shadow hover:border-indigo-200 transition min-w-[220px]">
            <div class="w-14 h-14 mb-4 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-600 font-bold text-xl">软件</div>
            <p class="text-lg font-bold text-gray-900 mb-2">软件套件</p>
            <p class="text-sm text-gray-500 mb-1"><a href="https://www.lxware.cn/1panel" target="_blank" class="inline-flex items-center hover:underline"><span>1Panel 专业版</span><Icon name="tabler:external-link" class="ml-1" /></a></p>
            <p class="text-sm text-gray-500 mb-1">OpenClaw/CoPaw 专属优化版</p>
            <p class="text-sm text-gray-500 mb-1"><a href="https://maxkb.cn/price" target="_blank" class="inline-flex items-center hover:underline"><span>MaxKB 专业版(可选)</span><Icon name="tabler:external-link" class="ml-1" /></a></p>
            <p class="text-xs text-gray-400 mt-2">* 含一年软件维保</p>
          </div>
          <!-- 服务 -->
          <div class="flex-1 flex flex-col items-center text-center rounded-2xl border-2 border-purple-100 bg-white p-6 shadow hover:border-purple-200 transition min-w-[220px]">
            <div class="w-14 h-14 mb-4 rounded-xl bg-purple-50 flex items-center justify-center text-purple-600 font-bold text-xl">
              服务
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">专属交流群</h3>
            <p class="text-sm text-gray-500 mb-1">应用场景交流</p>
            <p class="text-sm text-gray-500 mb-1">最佳实践分享</p>
            <p class="text-sm text-gray-500 mb-1">同行业案例分享</p>
            <p class="text-xs text-gray-400 mt-2">* 5x8 线上支持</p>
          </div>
        </div>
        <!-- 价格区块 -->
        <div class="rounded-2xl border border-gray-100 bg-indigo-50/40 p-8 shadow-lg flex flex-col md:flex-row gap-6 md:gap-0 md:items-center md:justify-center">

          <!-- 左侧：原价与限时价 -->
          <div class="flex flex-col items-center md:items-end md:pr-12 flex-1 md:max-w-[320px]">
            <div class="mb-3 w-full flex justify-start md:justify-end">
              <span class="inline-block bg-indigo-100 text-indigo-700 text-xs font-semibold px-2 py-0.5 rounded">基础款</span>
            </div>
            <div class="text-xl sm:text-2xl font-bold text-indigo-600 mb-3 w-full text-left md:text-right">￥5.9万/台</div>
          </div>

          <!-- 分割竖线，仅桌面端显示 -->
          <div class="hidden md:block h-36 w-px bg-gray-200 mx-12"></div>

          <!-- 右侧：二维码及文案 -->
          <div class="flex flex-col items-center flex-1 md:max-w-[320px]">
            <img 
              src="/images/wecom-qrcode.png" 
              alt="微信扫码咨询" 
              class="w-32 h-32 rounded-lg border border-gray-200 shadow-sm bg-white p-2 mb-2"
            />
            <div class="text-base font-semibold text-gray-800 mb-1 text-center">
              限时特价优惠中，微信扫码咨询
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 本地 AI 模型性能（基于同款硬件实测） -->
    <section class="section-padding bg-gradient-to-b from-white to-gray-50 border-t border-gray-100">
      <div class="container-custom">
        <div class="text-center mb-16">
          <h2 class="section-title text-4xl lg:text-5xl font-bold text-gray-800 mb-6">
            <span class="text-1panel-gradient">本地 AI 模型</span>
            性能
          </h2>
          <p class="section-subtitle text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">基于同款硬件的 Qwen3.6-35B-A3B 实测数据，开源可复现，全面超越 GPT-OSS-120B </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
          <!-- 推理速度 -->
          <div class="rounded-2xl bg-white border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 bg-indigo-50/50">
              <h3 class="text-lg font-bold text-gray-900">推理速度（vLLM，BF16）</h3>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-4 py-3 text-left font-semibold text-gray-700">场景</th>
                    <th class="px-4 py-3 text-left font-semibold text-gray-700">输出长度</th>
                    <th class="px-4 py-3 text-right font-semibold text-gray-700">速度</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  <tr><td class="px-4 py-3 text-gray-700">短回复</td><td class="px-4 py-3 text-gray-600">128 tokens</td><td class="px-4 py-3 text-right font-semibold text-indigo-600">约 31 TPS</td></tr>
                  <tr><td class="px-4 py-3 text-gray-700">中等回复</td><td class="px-4 py-3 text-gray-600">1,024 tokens</td><td class="px-4 py-3 text-right font-semibold text-indigo-600">约 32 TPS</td></tr>
                  <tr><td class="px-4 py-3 text-gray-700">长回复</td><td class="px-4 py-3 text-gray-600">3,831 tokens</td><td class="px-4 py-3 text-right font-semibold text-indigo-600">约 32 TPS</td></tr>
                </tbody>
              </table>
            </div>
            <p class="px-6 py-3 text-xs text-gray-500 border-t border-gray-100">首 token 延迟约 0.1s，输出长度变化下速度稳定</p>
          </div>

          <!-- 多用户并发 -->
          <div class="rounded-2xl bg-white border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 bg-indigo-50/50">
              <h3 class="text-lg font-bold text-gray-900">多用户并发（RAG 场景）</h3>
            </div>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-4 py-3 text-left font-semibold text-gray-700">并发用户</th>
                    <th class="px-4 py-3 text-left font-semibold text-gray-700">适用场景</th>
                    <th class="px-4 py-3 text-right font-semibold text-gray-700">总吞吐</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  <tr><td class="px-4 py-3 text-gray-700">5～10 人</td><td class="px-4 py-3 text-gray-600">小团队助手</td><td class="px-4 py-3 text-right font-semibold text-indigo-600">65～82 TPS</td></tr>
                  <tr><td class="px-4 py-3 text-gray-700">20～50 人</td><td class="px-4 py-3 text-gray-600">部门级部署</td><td class="px-4 py-3 text-right font-semibold text-indigo-600">186～308 TPS</td></tr>
