---
import { Icon } from 'astro-icon/components';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BlogPageDecor from '../../../components/blog/BlogPageDecor.astro';
import BlogLanguageSwitcher from '../../../components/blog/BlogLanguageSwitcher.astro';
import { getCollection } from 'astro:content';
import { NON_DEFAULT_LOCALES, SUPPORTED_LOCALES } from '../../../i18n/config';
import type { Locale } from '../../../i18n/config';
import { getTranslations, t, getBasePath } from '../../../i18n/utils';
import {
  blogListPath,
  type BlogPost,
  collectArticleSlugs,
  resolvePost,
  articleSlugFromEntry,
  absoluteBlogPostUrl,
  BLOG_DATE_LOCALE,
  schemaInLanguage,
} from '../../../lib/blog';
import '../../../styles/global.css';

export async function getStaticPaths() {
  const all = await getCollection('blog');
  const articleSlugs = collectArticleSlugs(all);
  const paths: {
    params: { lang: string; slug: string };
    props: { post: BlogPost; lang: string; articleSlug: string; isFallback: boolean };
  }[] = [];

  for (const lang of NON_DEFAULT_LOCALES) {
    for (const articleSlug of articleSlugs) {
      const post = resolvePost(all, lang, articleSlug);
      if (!post) continue;
      const isFallback = post.slug !== `${lang}/${articleSlug}`;
      paths.push({
        params: { lang, slug: articleSlug },
        props: { post, lang, articleSlug, isFallback },
      });
    }
  }
  return paths;
}

const { post, lang, articleSlug, isFallback } = Astro.props;
const { Content } = await post.render();
const locale = (lang ?? 'en') as Locale;
const translations = getTranslations(lang ?? 'en');
const basePath = getBasePath(lang);
const title = `${post.data.title} | 1Panel`;
const description = post.data.description;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const publishedIso = post.data.pubDate.toISOString();
const modifiedIso = (post.data.updatedDate ?? post.data.pubDate).toISOString();
const ogImageUrl = post.data.heroImage
  ? new URL(post.data.heroImage, Astro.site).href
  : undefined;
const keywords = ['1Panel', 'blog', ...post.data.tags].join(',');
const dateLocale = BLOG_DATE_LOCALE[locale] ?? 'en-US';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: publishedIso,
  dateModified: modifiedIso,
  url: canonicalUrl,
  inLanguage: schemaInLanguage(lang ?? 'en'),
  image: ogImageUrl ? [ogImageUrl] : undefined,
  author: {
    '@type': 'Organization',
    name: 'LXware',
  },
  publisher: {
    '@type': 'Organization',
    name: '1Panel',
  },
};
---

<Layout
  title={title}
  description={description}
  lang={lang}
  basePath={basePath}
  ogType="article"
  canonicalUrl={canonicalUrl}
  articlePublishedTime={publishedIso}
  articleModifiedTime={modifiedIso}
  keywords={keywords}
  ogImageUrl={ogImageUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {SUPPORTED_LOCALES.map((loc) => (
      <link
        rel="alternate"
        hreflang={loc}
        href={absoluteBlogPostUrl(Astro.site, loc === 'en' ? undefined : loc, articleSlug)}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={absoluteBlogPostUrl(Astro.site, undefined, articleSlug)} />
  </Fragment>
  <Fragment slot="main">
    <Header lang={lang} basePath={basePath} translations={translations} />
    <main class="relative z-10 min-h-screen">
      <div class="relative overflow-hidden bg-gradient-to-br from-gray-50 to-white text-gray-900">
        <BlogPageDecor />
        <section class="relative z-10 pt-6 pb-16 sm:pt-8 sm:pb-20 lg:pt-10 lg:pb-24">
          <div class="container-custom max-w-5xl text-gray-900">
            <nav
              class="inline-flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-gray-600 mb-5 px-4 py-2.5 rounded-full bg-white/90 border border-gray-200/90 shadow-sm backdrop-blur-sm"
              aria-label="Breadcrumb"
            >
              <a href={blogListPath(lang)} class="inline-flex items-center gap-1.5 hover:text-1panel transition-colors font-medium">
                <Icon name="carbon:arrow-left" class="w-4 h-4" />
                {t(translations, 'blogs.heading')}
              </a>
              <span class="text-gray-300 select-none" aria-hidden="true">/</span>
              <span class="text-gray-800 font-medium line-clamp-2">{post.data.title}</span>
            </nav>

            <div class="card p-6 sm:p-8 lg:p-10 shadow-lg border-gray-200/90">
              <article>
                {isFallback && (
                  <p class="text-sm text-amber-900 bg-amber-50 border border-amber-200/80 rounded-lg px-4 py-3 mb-6" role="status">
                    {t(translations, 'blogs.fallbackToEnglish')}
                  </p>
                )}
                <header class="mb-8 pb-6 border-b border-gray-100">
                  <h1 class="text-3xl sm:text-4xl lg:text-[2.5rem] font-bold text-gray-900 leading-tight mb-3">
                    {post.data.title}
                  </h1>
                  <p class="text-lg text-gray-700 leading-relaxed mb-4">{post.data.description}</p>
                  <div class="flex flex-wrap items-center gap-3">
                    <span class="inline-flex items-center gap-2 text-sm text-gray-500">
                      <Icon name="carbon:calendar" class="w-4 h-4 text-1panel/80" />
                      <time datetime={publishedIso}>
                        {post.data.pubDate.toLocaleDateString(dateLocale, {
                          year: 'numeric',
                          month: 'long',
                          day: 'numeric',
                        })}
                      </time>
                    </span>
                    {post.data.tags.length > 0 && (
                      <span class="hidden sm:inline text-gray-300" aria-hidden="true">·</span>
                    )}
                    {post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {post.data.tags.map((tag: string) => (
                          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-800 border border-blue-100">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </header>
                <div class="blog-content">
                  <Content />
                </div>
                <BlogLanguageSwitcher currentLang={locale} articleSlug={articleSlug} translations={translations} />
              </article>
            </div>
          </div>
        </section>
      </div>
    </main>
    <Footer lang={lang} basePath={basePath} translations={translations} />
  </Fragment>
</Layout>

<style>
  main {
    position: relative;
    z-index: 1;
  }
</style>
