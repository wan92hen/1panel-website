---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PricingContent from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';
import { getTranslations, t, getBasePath } from '../i18n/utils';
import { SUPPORTED_LOCALES } from '../i18n/config';
import '../styles/global.css';

const lang = 'en';
const translations = getTranslations(lang);
const basePath = getBasePath(undefined);
const title = t(translations, 'pricing.metaTitle');
const description = t(translations, 'pricing.metaDescription');
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const pricingFaqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: t(translations, 'pricing.faq.trialQ'),
      acceptedAnswer: {
        '@type': 'Answer',
        text: t(translations, 'pricing.faq.trialA'),
      },
    },
    {
      '@type': 'Question',
      name: t(translations, 'pricing.faq.subVsPerpQ'),
      acceptedAnswer: {
        '@type': 'Answer',
        text: t(translations, 'pricing.faq.subVsPerpA'),
      },
    },
    {
      '@type': 'Question',
      name: t(translations, 'pricing.faq.v3Q'),
      acceptedAnswer: {
        '@type': 'Answer',
        text: t(translations, 'pricing.faq.v3A'),
      },
    },
    {
      '@type': 'Question',
      name: t(translations, 'pricing.faq.devicesQ'),
      acceptedAnswer: {
        '@type': 'Answer',
        text: t(translations, 'pricing.faq.devicesA'),
      },
    },
    {
      '@type': 'Question',
      name: t(translations, 'pricing.faq.multiNodeQ'),
      acceptedAnswer: {
        '@type': 'Answer',
        text: t(translations, 'pricing.faq.multiNodeA').replace('NODE_DOCS_LINK', 'Node Management documentation'),
      },
    },
    {
      '@type': 'Question',
      name: t(translations, 'pricing.faq.lxwareQ'),
      acceptedAnswer: {
        '@type': 'Answer',
        text: t(translations, 'pricing.faq.lxwareA').replace(/\{\{lxware\}\}/g, 'LXware'),
      },
    },
  ],
};
---

<Layout title={title} description={description} lang={lang} basePath={basePath} canonicalUrl={canonicalUrl}>
  <Fragment slot="head">
    {SUPPORTED_LOCALES.map((loc) => (
      <link
        rel="alternate"
        hreflang={loc}
        href={new URL(loc === 'en' ? '/pricing' : `/${loc}/pricing`, Astro.site).href}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/pricing', Astro.site).href} />
    <script type="application/ld+json" set:html={JSON.stringify(pricingFaqJsonLd)} />
  </Fragment>
  <Fragment slot="main">
    <Header lang={lang} basePath={basePath} translations={translations} />
    <main>
      <PricingContent lang={lang} basePath={basePath} translations={translations} />
    </main>
    <Footer lang={lang} basePath={basePath} translations={translations} />
  </Fragment>
</Layout>

<style>
  main {
    position: relative;
    z-index: 1;
  }
</style>

