---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PricingContent from '../components/Pricing.astro';
import Footer from '../components/Footer.astro';
import { getTranslations, t, getBasePath } from '../i18n/utils';
import '../styles/global.css';

const lang = 'en';
const translations = getTranslations(lang);
const basePath = getBasePath(undefined);
const title = `${t(translations, 'header.pricing')} - 1Panel`;
---

<Layout title={title} lang={lang} basePath={basePath}>
  <Fragment slot="main">
    <Header lang={lang} basePath={basePath} translations={translations} />
    <main>
      <PricingContent lang={lang} basePath={basePath} translations={translations} />
    </main>
    <Footer lang={lang} basePath={basePath} translations={translations} />
  </Fragment>
</Layout>

<style>
  main {
    position: relative;
    z-index: 1;
  }
</style>

