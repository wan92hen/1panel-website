---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Statistics from "../components/Statistics.astro";
import { Icon } from "astro-icon/components";
import {
  SITE_URL,
  createBreadcrumbSchema,
  toAbsoluteUrl,
} from "../lib/seo";
import "../styles/global.css";

const siteUrl = Astro.site?.toString() ?? SITE_URL;
const enterprisePageUrl = toAbsoluteUrl("/enterprise.html", siteUrl);
const trialUrl = "https://jsj.top/f/umuYtv";

const layerTabs = [
  {
    id: "application-layer",
    name: "应用层",
    subtitle: "AI 应用全生命周期管理",
    icon: "carbon:application",
    color: "blue",
    description:
      "支持通过 1Panel 应用商店快速部署和管理 AI 编程工具、AI 助理与智能体开发平台，让企业更容易统一管理多样化 AI 应用。",
    items: ["OpenCode", "OpenClaw", "Hermes", "MaxKB", "n8n", "..."],
    groups: ["AI 编程", "AI 助理", "智能体开发平台"],
  },
  {
    id: "governance-layer",
    name: "治理层",
    subtitle: "企业级 AI 治理",
    icon: "carbon:security",
    color: "indigo",
    description:
      "通过 AI 网关、多用户管理、权限治理、用量统计、审计和安全运维能力，帮助企业从个人使用 AI 走向可管理、可追踪的组织级使用。",
    items: ["AI 网关", "Skills商店"],
    groups: [],
  },
  {
    id: "model-layer",
    name: "模型层",
    subtitle: "算力与模型支持",
    icon: "carbon:machine-learning-model",
    color: "cyan",
    description:
      "提供本地模型统一管理能力，支持 DeepSeek、Qwen 等主流开源大模型，并适配 NVIDIA、Intel、华为昇腾等主流算力环境。",
    items: ["Qwen", "deepseek", "KIMI", "...", "NVIDIA", "华为昇腾", "Intel"],
    groups: [],
  },
];

const enterpriseOnlyCapabilities = [
  {
    icon: "carbon:gateway",
    title: "AI 网关",
    href: "/ai-gateway.html",
    tag: "统一入口",
    description:
      "为内部 AI 应用和模型调用提供统一接入入口，便于集中管理模型访问、使用统计和调用链路。",
    points: ["统一代理", "模型接入", "用量统计"],
  },
  {
    icon: "carbon:headset",
    title: "Skills 商店",
    href: "/skills-hub.html",
    tag: "持续积累",
    description:
      "在组织内发布、发现和管理可复用的 Skills 技能，确保可审计、可治理。",
    points: ["统一管理","安全审计", "技能沉淀"],
  },
  {
    icon: "carbon:user-multiple",
    title: "用户管理",
    href: "/user-management.html",
    tag: "组织协作",
    description:
      "面向部门和企业内部多角色使用场景，支持用户与权限管理，让 AI 能力在团队内有序开放。",
    points: ["用户管理", "权限分配", "协作使用"],
  },
  {
    icon: "carbon:report",
    title: "安全运维报表",
    href: "/security-ops-report.html",
    tag: "持续可见",
    description:
      "将系统、模型、智能体、网站、安全和运维侧的关键状态沉淀成报表，帮助管理员发现待关注项。",
    points: ["风险概览", "运维状态", "报表沉淀"],
  },
  {
    icon: "carbon:network-4",
    title: "多节点纳管",
    tag: "集中运维",
    description:
      "支持纳管 20 个节点，适合需要统一查看和管理多台服务器资源的企业环境。",
    points: ["20 个节点", "统一视图", "集中管理"],
  },
  {
    icon: "carbon:cloud-offline",
    title: "纯离线环境适配",
    tag: "本地可控",
    description:
      "适配网络边界要求更高的部署场景，让 AI 应用、模型和管理能力运行在企业自有环境内。",
    points: ["离线部署", "私有环境", "数据边界"],
  },
];

const layerClassMap = {
  blue: {
    badge: "bg-blue-50 text-1panel",
    border: "border-blue-100",
    icon: "bg-blue-50 text-1panel",
    accent: "from-blue-50 to-white",
  },
  indigo: {
    badge: "bg-indigo-50 text-indigo-600",
    border: "border-indigo-100",
    icon: "bg-indigo-50 text-indigo-600",
    accent: "from-indigo-50 to-white",
  },
  cyan: {
    badge: "bg-cyan-50 text-cyan-700",
    border: "border-cyan-100",
    icon: "bg-cyan-50 text-cyan-700",
    accent: "from-cyan-50 to-white",
  },
};

const pageTitle = "1Panel 企业版 - 轻量级 AI 管理平台";
const pageDescription =
  "1Panel 企业版定位为轻量级 AI 管理平台，是从底层硬件到智能体（Metal-to-Agent）的统一管理平台。";
const enterpriseSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "@id": `${enterprisePageUrl}#product`,
  name: "1Panel 企业版",
  alternateName: "1Panel Enterprise Edition",
  applicationCategory: "DeveloperApplication",
  applicationSubCategory: "AI management platform",
  operatingSystem: "Linux",
  description: pageDescription,
  url: enterprisePageUrl,
  audience: {
    "@type": "BusinessAudience",
    audienceType: "企业、部门级 AI 部署团队、运维管理团队",
  },
  softwareRequirements: "Linux 服务器环境",
  featureList: [
    "AI 网关",
    "Skills 商店",
    "多用户管理",
    "安全运维报表",
    "多节点纳管",
    "纯离线环境适配",
    "AI 应用一键部署",
    "本地模型管理",
  ],
  offers: {
    "@type": "Offer",
    price: "30000",
    priceCurrency: "CNY",
    availability: "https://schema.org/InStock",
    url: enterprisePageUrl,
    seller: {
      "@type": "Organization",
      name: "杭州飞致云信息科技有限公司",
    },
  },
};
---

<Layout
  title={pageTitle}
  socialTitle="1Panel 企业版 - 轻量级 AI 管理平台"
  schemaName="1Panel 企业版"
  description={pageDescription}
  canonical="/enterprise.html"
  image="/images/overview-full.png"
  imageAlt="1Panel 企业版介绍"
  keywords={[
    "1Panel 企业版",
    "1Panel AI 网关",
    "Skills 商店",
    "轻量级 AI 管理平台",
    "私有化 AI 部署",
    "AI 应用部署",
    "多用户管理",
    "安全运维报表",
    "纯离线部署",
  ]}
  structuredData={[
    createBreadcrumbSchema([
      { name: "1Panel 官网", url: toAbsoluteUrl("/", siteUrl) },
      { name: "1Panel 企业版", url: enterprisePageUrl },
    ]),
    enterpriseSchema,
  ]}
>
  <Statistics slot="head" />
  <Fragment slot="main">
    <Header />
    <main class="relative z-10 bg-white text-gray-800">
      <section class="relative overflow-hidden bg-gradient-to-b from-blue-50/80 via-white to-white pt-20 pb-12 lg:pt-28 lg:pb-16">
        <div class="container-custom">
          <div class="fade-in-up mx-auto mb-10 max-w-3xl text-center lg:mb-12" style="animation-delay: 0.1s;">
            <h1 class="text-4xl font-bold leading-tight tracking-normal text-gray-950 sm:text-5xl lg:text-6xl">
              1Panel 企业版
            </h1>
            <p class="mt-4 text-2xl font-semibold leading-tight tracking-normal text-gray-900 sm:text-3xl lg:text-4xl">
              轻量级 AI 管理平台
            </p>
            <p class="mt-4 text-base leading-relaxed text-gray-600 sm:text-lg">
              打造企业专属的 AI 自主环境，助力企业在 AI 快速部署与企业级安全管控之间实现平衡。
            </p>
            <a href={trialUrl} target="_blank" rel="noopener noreferrer" class="btn-primary mt-7 inline-flex items-center justify-center px-9 py-4 text-base">
              申请试用
              <Icon name="carbon:arrow-right" class="ml-2 h-5 w-5" />
            </a>
          </div>

          <div id="architecture" class="fade-in-up mt-10 rounded-lg border border-blue-100 bg-white/90 p-4 shadow-lg shadow-blue-100/50 sm:p-5 lg:mt-12 lg:p-6" style="animation-delay: 0.18s;">
            <h2 class="mb-5 flex items-center gap-2 text-lg font-bold text-gray-950">
              <span class="h-5 w-1 rounded-full bg-1panel"></span>
              企业版功能架构
            </h2>
            <div class="grid grid-cols-1 items-center gap-6 lg:grid-cols-[minmax(0,1fr)_52px_260px]">
              <div class="space-y-3">
                <a href="#application-layer" class="group grid grid-cols-1 overflow-hidden rounded-lg border border-gray-100 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-200 hover:shadow-lg sm:grid-cols-[132px_minmax(0,1fr)]">
                  <div class="flex items-center justify-center gap-2 bg-blue-50/70 px-4 py-4 text-lg font-bold text-[#07365e] sm:justify-start">
                    <Icon name="carbon:application" class="h-5 w-5 text-1panel" />
                    应用层
                  </div>
                  <div class="p-4">
                    <div class="flex flex-wrap items-center justify-center gap-3 xl:flex-nowrap">
                      {["OpenCode", "OpenClaw", "Hermes", "MaxKB", "n8n"].map((item) => (
                        <span class="min-w-[96px] rounded-md border border-gray-200 bg-white px-3 py-1.5 text-center text-sm font-semibold text-gray-950 shadow-sm">
                          {item}
                        </span>
                      ))}
                      <span class="min-w-[52px] rounded-md border border-gray-200 bg-white px-3 py-1.5 text-center text-sm font-semibold text-gray-950 shadow-sm">...</span>
                    </div>
                    <div class="mt-3 grid grid-cols-1 gap-2 text-center text-sm font-semibold text-1panel sm:grid-cols-3">
                      <span>AI 编程</span>
                      <span>AI 助理</span>
                      <span>智能体开发平台</span>
                    </div>
                  </div>
                </a>

                <a href="#governance-layer" class="group grid grid-cols-1 overflow-hidden rounded-lg border border-gray-100 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-200 hover:shadow-lg sm:grid-cols-[132px_minmax(0,1fr)]">
                  <div class="flex items-center justify-center gap-2 bg-blue-50/70 px-4 py-4 text-lg font-bold text-[#07365e] sm:justify-start">
                    <Icon name="carbon:security" class="h-5 w-5 text-1panel" />
                    治理层
                  </div>
                  <div class="grid grid-cols-1 gap-4 p-4 sm:grid-cols-2">
                    <span class="rounded-md border border-gray-200 bg-white px-4 py-2 text-center text-base font-semibold text-gray-950 shadow-sm">
                      AI 网关
                    </span>
                    <span class="rounded-md border border-gray-200 bg-white px-4 py-2 text-center text-base font-semibold text-gray-950 shadow-sm">
                      Skills 商店
                    </span>
                  </div>
                </a>

                <a href="#model-layer" class="group grid grid-cols-1 overflow-hidden rounded-lg border border-gray-100 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-200 hover:shadow-lg sm:grid-cols-[132px_minmax(0,1fr)]">
                  <div class="flex items-center justify-center gap-2 bg-blue-50/70 px-4 py-4 text-lg font-bold text-[#07365e] sm:justify-start">
                    <Icon name="carbon:machine-learning-model" class="h-5 w-5 text-1panel" />
                    模型层
                  </div>
                  <div class="p-4">
                    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 rounded-md bg-white">
                      <span class="inline-flex items-center gap-2 text-2xl font-bold text-[#5268f2]">
                        <img src="/images/enterprise-qwen.svg" alt="Qwen" class="h-9 w-9 object-contain" loading="eager" />
                        Qwen
                      </span>
                      <img src="/images/enterprise-deepseek.png" alt="deepseek" class="h-9 w-auto max-w-[180px] object-contain" loading="eager" />
                      <span class="inline-flex items-center gap-2 text-xl font-bold text-gray-950">
                        <img src="/images/enterprise-kimi.webp" alt="KIMI" class="h-9 w-9 rounded-lg object-contain" loading="eager" />
                        KIMI
                      </span>
                      <span class="text-xl font-bold text-gray-950">...</span>
                    </div>
                    <div class="mt-4 grid grid-cols-1 gap-3 rounded-md bg-blue-100/70 p-3 sm:grid-cols-3">
                      {["NVIDIA", "华为昇腾", "Intel"].map((item) => (
                        <span class="rounded-md border border-white/80 bg-white px-4 py-1.5 text-center text-sm font-semibold text-gray-950 shadow-sm">
                          {item}
                        </span>
                      ))}
                    </div>
                  </div>
                </a>
              </div>

              <div class="hidden justify-center lg:flex">
                <div class="flex h-[260px] w-10 items-center justify-center font-serif text-[170px] font-thin leading-none text-blue-300" style="transform: scaleX(0.45);" aria-hidden="true">
                  {"}"}
                </div>
              </div>

              <div class="rounded-lg bg-white/70 p-4 text-center lg:text-left">
                <h2 class="text-2xl font-bold text-gray-950 lg:text-3xl">1Panel 企业版</h2>
                <p class="mt-5 text-base font-semibold leading-relaxed text-gray-600">
                  从底层硬件到智能体（Metal-to-Agent）的统一管理平台
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-16 lg:py-24">
        <div class="container-custom">
          <div class="mx-auto mb-12 max-w-3xl text-center">
            <h2 class="text-3xl font-bold text-gray-900 lg:text-5xl">把 AI 用起来，也把 AI 管起来</h2>
          </div>
          <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
            {enterpriseOnlyCapabilities.map((capability) => {
              const content = (
                <>
                  <div class="mb-5 flex items-start justify-between gap-4">
                    <span class="inline-flex h-12 w-12 items-center justify-center rounded-lg bg-blue-50 text-1panel">
                      <Icon name={capability.icon} class="h-6 w-6" />
                    </span>
                    <span class="rounded-full bg-gray-50 px-3 py-1 text-xs font-semibold text-gray-500">{capability.tag}</span>
                  </div>
                  <h3 class="text-xl font-bold text-gray-900">{capability.title}</h3>
                  <p class="mt-3 min-h-[72px] text-sm leading-relaxed text-gray-600">{capability.description}</p>
                  <div class="mt-5 flex flex-wrap gap-2">
                    {capability.points.map((point) => (
                      <span class="rounded-md bg-blue-50 px-3 py-1 text-xs font-semibold text-1panel">{point}</span>
                    ))}
                  </div>
                </>
              );

              return capability.href ? (
                <a href={capability.href} class="block rounded-lg border border-gray-100 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl">
                  {content}
                </a>
              ) : (
                <article class="rounded-lg border border-gray-100 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-100 hover:shadow-xl">
                  {content}
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <section class="bg-gray-50 py-16 lg:py-24">
        <div class="container-custom">
          <div class="mx-auto mb-12 max-w-3xl text-center">
            <h2 class="text-3xl font-bold text-gray-900 lg:text-5xl">三层架构支撑企业 AI 自主环境</h2>
          </div>
          <div class="space-y-8">
            {layerTabs.map((layer, index) => {
              const colors = layerClassMap[layer.color];
              return (
                <article id={layer.id} class="scroll-mt-28 rounded-lg border border-gray-100 bg-white p-6 shadow-sm lg:p-8">
                  <div class="grid grid-cols-1 gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
                    <div>
                      <div class={`inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold ${colors.badge}`}>
                        <Icon name={layer.icon} class="h-4 w-4" />
                        {layer.name}
                      </div>
                      <h3 class="mt-5 text-2xl font-bold text-gray-900 lg:text-3xl">{layer.subtitle}</h3>
                      <p class="mt-4 text-base leading-relaxed text-gray-600">{layer.description}</p>
                    </div>
                    <div class={`rounded-lg border ${colors.border} bg-gradient-to-br ${colors.accent} p-5`}>
                      {layer.id === "model-layer" ? (
                        <>
                          <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4 rounded-md bg-white/80 p-4 shadow-sm">
                            <span class="inline-flex items-center gap-2 text-2xl font-bold text-[#5268f2]">
                              <img src="/images/enterprise-qwen.svg" alt="Qwen" class="h-9 w-9 object-contain" loading="lazy" />
                              Qwen
                            </span>
                            <img src="/images/enterprise-deepseek.png" alt="deepseek" class="h-9 w-auto max-w-[180px] object-contain" loading="lazy" />
                            <span class="inline-flex items-center gap-2 text-xl font-bold text-gray-950">
                              <img src="/images/enterprise-kimi.webp" alt="KIMI" class="h-9 w-9 rounded-md object-contain" loading="lazy" />
                              KIMI
                            </span>
                            <span class="text-2xl font-bold text-gray-950">...</span>
                          </div>
                          <div class="mt-5 grid grid-cols-1 gap-3 rounded-md bg-blue-100 p-4 sm:grid-cols-3">
                            {["NVIDIA", "华为昇腾", "Intel"].map((item) => (
                              <div class="rounded-md border border-white/80 bg-white p-4 text-center text-sm font-semibold text-gray-800 shadow-sm">
                                {item}
                              </div>
                            ))}
                          </div>
                        </>
                      ) : (
                        <>
                          <div class={`grid grid-cols-1 gap-3 sm:grid-cols-2 ${layer.id === "governance-layer" ? "mx-auto w-full max-w-2xl" : "lg:grid-cols-3"}`}>
                            {layer.items.map((item) => (
                              <div class="rounded-md border border-white/80 bg-white p-4 text-center text-sm font-semibold text-gray-800 shadow-sm">
                                {item}
                              </div>
                            ))}
                          </div>
                          {layer.groups.length > 0 && (
                            <div class="mt-5 flex flex-wrap gap-2">
                              {layer.groups.map((group) => (
                                <span class="rounded-full bg-white/80 px-3 py-1 text-xs font-semibold text-gray-500">{group}</span>
                              ))}
                            </div>
                          )}
                        </>
                      )}
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <section id="price" class="py-16 lg:py-24">
        <div class="container-custom">
          <div class="grid grid-cols-1 items-center gap-8 rounded-lg border border-blue-100 bg-blue-50/50 p-6 shadow-sm lg:grid-cols-[0.9fr_1.1fr] lg:p-10">
            <div class="lg:pr-6">
              <h2 class="text-3xl font-bold leading-tight text-gray-900 lg:text-4xl">1Panel 企业版的价格</h2>
              <p class="mt-5 text-base leading-relaxed text-gray-600">
                一个套软件，实现从底层硬件到智能体（Metal-to-Agent）的统一管理。
              </p>
            </div>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <div class="rounded-lg bg-white p-5 shadow-sm">
                <div class="text-3xl font-bold text-1panel">￥3万</div>
                <p class="mt-2 text-sm text-gray-500">企业版软件授权价格，适合部门级预算快速决策。</p>
              </div>
              <div class="rounded-lg bg-white p-5 shadow-sm">
                <div class="text-3xl font-bold text-1panel">5x8</div>
                <p class="mt-2 text-sm text-gray-500">企业级线上支持服务，保障企业部署和日常使用。</p>
              </div>
              <div class="rounded-lg bg-white p-5 shadow-sm">
                <div class="text-3xl font-bold text-1panel">20</div>
                <p class="mt-2 text-sm text-gray-500">支持纳管 20 个节点，满足多节点统一管理场景。</p>
              </div>
              <div class="rounded-lg bg-white p-5 shadow-sm">
                <div class="text-3xl font-bold text-1panel">离线</div>
                <p class="mt-2 text-sm text-gray-500">适配纯离线环境，适合网络边界要求更高的部署场景。</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="contact" class="bg-white pb-16 lg:pb-24">
        <div class="container-custom">
          <div class="grid grid-cols-1 items-center gap-8 rounded-lg border border-blue-100 bg-gradient-to-r from-blue-50 to-white p-6 shadow-sm sm:p-8 lg:grid-cols-[1fr_auto] lg:p-10">
            <div>
              <h2 class="text-2xl font-bold text-gray-900 lg:text-3xl">
                想了解企业版是否适合你的 AI 部署场景？
              </h2>
              <p class="mt-4 max-w-2xl text-base leading-relaxed text-gray-600">
                微信扫码联系飞致云团队。
              </p>
            </div>
            <div class="flex flex-col items-center justify-center rounded-lg bg-white p-5 shadow-sm">
              <img
                src="/images/wecom-qrcode.png"
                alt="微信扫码咨询 1Panel 企业版"
                class="h-36 w-36 rounded-md border border-gray-200 bg-white p-2"
                loading="lazy"
              />
              <div class="mt-3 text-center text-sm font-semibold text-gray-800">微信扫码咨询</div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </Fragment>
</Layout>
