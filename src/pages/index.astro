---
import Layout from '../layouts/Layout.astro';
import Statistics from '../components/Statistics.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import QuickStart from '../components/QuickStart.astro';
import AppStore from '../components/AppStore.astro';
import Community from '../components/Community.astro';
import Partners from '../components/Partners.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import LanguageModal from '../components/LanguageModal.astro';
import {
  createSoftwareApplicationSchema,
} from '../lib/seo';
import '../styles/global.css';
---

<Layout
  title="1Panel - 现代化、开源的Linux服务器运维管理面板"
  socialTitle="1Panel 官网 - 现代化、开源的 Linux 服务器运维管理面板"
  schemaName="1Panel 官网"
  description="1Panel 是现代化、开源的 Linux 服务器运维管理面板，提供网站、数据库、容器、文件、备份与安全管理，支持应用商店一键部署及本地 AI 模型与智能体管理。"
  canonical="/"
  keywords={[
    "1Panel",
    "1Panel 官网",
    "Linux 面板",
    "Linux 服务器运维管理面板",
    "开源 Linux 面板",
    "Docker 管理",
    "服务器运维",
    "应用商店",
    "数据库管理",
    "AI 模型管理",
  ]}
  structuredData={[createSoftwareApplicationSchema()]}
>
  <Statistics slot="head" />
  <Fragment slot="main">
    <Header />
    <main>
      <Hero />
      <Features />
      <AppStore />
      <QuickStart />
      <Community />
      <Partners />
      <CTA />
    </main>
    <Footer />
    <LanguageModal />
  </Fragment>
</Layout>

<style>
  main {
    position: relative;
    z-index: 1;
  }
</style>
