---
import Layout from "../layouts/Layout.astro";
import Statistics from "../components/Statistics.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import LanguageModal from "../components/LanguageModal.astro";
import {
  SITE_URL,
  createBreadcrumbSchema,
} from "../lib/seo";
import "../styles/global.css";
---

<Layout
  title="1Panel 自托管解决方案"
  description="1Panel 自托管解决方案帮助团队在自有环境中部署开源软件，兼顾数据主权、成本可控与安全合规，适用于网站、知识库、密码管理、远程协作等多种场景。"
  canonical="/self-hosted.html"
  keywords={[
    "1Panel 自托管",
    "自托管解决方案",
    "开源软件自托管",
    "Linux 面板",
    "数据主权",
    "私有化部署",
  ]}
  structuredData={[
    createBreadcrumbSchema([
      { name: "1Panel 官网", url: `${SITE_URL}/` },
      { name: "1Panel 自托管解决方案", url: `${SITE_URL}/self-hosted.html` },
    ]),
  ]}
>
  <Statistics slot="head" />
  <Fragment slot="main">
    <Header />
    <main>
    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <h1>1Panel 自托管解决方案</h1>
            <p class="hero-subtitle">
                您是否因为商业 SaaS 平台的价格昂贵、不确定的数据安全风险而感到沮丧？
            </p>
        </div>
    </section>

    <!-- Section 1: Why Choose Self-Hosting -->
    <section>
        <div class="container">
            <h2 class="section-title">为什么选择自托管？</h2>
            <p class="section-subtitle">掌控您的数字资产，享受完全的数据主权</p>

            <div class="cards-grid">
                <div class="card">
                    <div class="card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path>
                        </svg>
                    </div>
                    <h3 class="card-title"><span class="card-title-accent">数据主权</span></h3>
                    <p class="card-description">
                        轻松实现合规性：数据完全存储于自有环境，轻松满足 GDPR、HIPAA、等保等法规对数据驻留、审计的要求，规避跨境传输风险。
                    </p>
                </div>

                <div class="card">
                    <div class="card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                        </svg>
                    </div>
                    <h3 class="card-title"><span class="card-title-accent">安全性</span></h3>
                    <p class="card-description">
                        加强您的安全性：本地部署使您的数据保持在您的控制之下，避免第三方接触敏感信息（如客户资料、内部文档）。
                    </p>
                </div>

                <div class="card">
                    <div class="card-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h3 class="card-title"><span class="card-title-accent">低成本</span></h3>
                    <p class="card-description">
                        降低您的成本：无需按坐席支持昂贵的订阅费用，硬件/运维成本明确可控，避免 SaaS 隐性涨价。
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Section 2: 1Panel Value Proposition -->
    <section class="section-gray">
        <div class="container">
            <h2 class="section-title">1Panel + 开源平替软件 = 最佳的自托管解决方案</h2>
            <p class="section-subtitle">现代化 Linux 服务器运维面板，让自托管变得简单高效</p>

            <div class="value-props">
                <div class="value-prop">
                    <div class="value-prop-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h3 class="value-prop-title">快速</h3>
                    <p class="value-prop-description">
                        一键部署、支持后续持续平滑升级<br>
                    </p>
                </div>

                <div class="value-prop">
                    <div class="value-prop-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
                        </svg>
                    </div>
                    <h3 class="value-prop-title">齐全</h3>
                    <p class="value-prop-description">
                        一站式汇聚各类知名开源软件<br>
                    </p>
                </div>

                <div class="value-prop">
                    <div class="value-prop-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                        </svg>
                    </div>
                    <h3 class="value-prop-title">可靠</h3>
                    <p class="value-prop-description">
                        内置多种安全防护、支持定期备份<br>
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Section 3: Supported Software -->
    <section>
        <div class="container">
            <h2 class="section-title">1Panel 支持的常见自托管软件</h2>
            <p class="section-subtitle">开源替代方案，满足您的多样化需求</p>

            <div class="software-grid">
                <div class="software-card">
                    <div class="software-main">
                        <div class="software-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
                            </svg>
                        </div>
                        <span class="software-name">OpenList</span>
                    </div>
                    <div class="software-divider"></div>
                    <div class="software-replace">
                        <span class="replace-badge">平替</span>
                        <span class="replace-arrow">→</span>
                        <span class="commercial-name">百度网盘</span>
                    </div>
                </div>

                <div class="software-card">
                    <div class="software-main">
                        <div class="software-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
                            </svg>
                        </div>
                        <span class="software-name">Bitwarden</span>
                    </div>
                    <div class="software-divider"></div>
                    <div class="software-replace">
                        <span class="replace-badge">平替</span>
                        <span class="replace-arrow">→</span>
                        <span class="commercial-name">1Password</span>
                    </div>
                </div>            

                <div class="software-card">
                    <div class="software-main">
                        <div class="software-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                        <span class="software-name">RustDesk</span>
                    </div>
                    <div class="software-divider"></div>
                    <div class="software-replace">
                        <span class="replace-badge">平替</span>
                        <span class="replace-arrow">→</span>
                        <span class="commercial-name">TeamViewer</span>
                    </div>
                </div>

                <div class="software-card">
                    <div class="software-main">
                        <div class="software-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path>
                            </svg>
                        </div>
                        <span class="software-name">NextCloud</span>
                    </div>
                    <div class="software-divider"></div>
                    <div class="software-replace">
                        <span class="replace-badge">平替</span>
                        <span class="replace-arrow">→</span>
                        <span class="commercial-name">Microsoft 365</span>
                    </div>
                </div>

                <div class="software-card">
                    <div class="software-main">
                        <div class="software-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                            </svg>
                        </div>
                        <span class="software-name">Gitea</span>
                    </div>
                    <div class="software-divider"></div>
                    <div class="software-replace">
                        <span class="replace-badge">平替</span>
                        <span class="replace-arrow">→</span>
                        <span class="commercial-name">GitHub</span>
                    </div>
                </div>

                <div class="software-card">
                    <div class="software-main">
                        <div class="software-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                            </svg>
                        </div>
                        <span class="software-name">Umami</span>
                    </div>
                    <div class="software-divider"></div>
                    <div class="software-replace">
                        <span class="replace-badge">平替</span>
                        <span class="replace-arrow">→</span>
                        <span class="commercial-name">Google Analytics</span>
                    </div>
                </div>
            </div>

            <div class="view-more">
                <a href="https://apps.fit2cloud.com/1panel" class="view-more-link">
                    更多软件请访问 1Panel 应用商店
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                </a>
            </div>
        </div>
    </section>

    </main>
    <Footer />
    <LanguageModal />
  </Fragment>
</Layout>

<style>
  /* Self-hosted page content styles */
  main .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  main .hero {
    background: linear-gradient(180deg, #F2F5FA 0%, #fff 100%);
    padding: 80px 0 60px;
    text-align: center;
  }

  main .hero h1 {
    font-size: 48px;
    font-weight: 700;
    color: #181B25;
    margin-bottom: 24px;
    letter-spacing: -1px;
  }

  main .hero-subtitle {
    font-size: 18px;
    color: #5F646C;
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.8;
  }

  main section {
    padding: 80px 0;
    background-color: #fff;
  }

  main .section-title {
    font-size: 36px;
    font-weight: 700;
    text-align: center;
    margin-bottom: 16px;
    color: #181B25;
  }

  main .section-subtitle {
    font-size: 16px;
    color: #5F646C;
    text-align: center;
    margin-bottom: 48px;
  }

  main .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  main .card {
    background: #fff;
    border: 1px solid #E3E6EB;
    border-radius: 12px;
    padding: 32px;
    transition: all 0.3s ease;
  }

  main .card:hover {
    box-shadow: 0 8px 24px rgba(0, 82, 217, 0.12);
    transform: translateY(-4px);
    border-color: #0052D9;
  }

  main .card-icon {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, #E8F0FE 0%, #D4E4FC 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  main .card-icon svg {
    width: 28px;
    height: 28px;
    color: #0052D9;
  }

  main .card-title {
    font-size: 20px;
    font-weight: 600;
    color: #181B25;
    margin-bottom: 12px;
  }

  main .card-title-accent {
    color: #0052D9;
    margin-right: 8px;
  }

  main .card-description {
    font-size: 15px;
    color: #5F646C;
    line-height: 1.7;
  }

  main .section-gray {
    background: #F8FAFC;
  }

  main .value-props {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  main .value-prop {
    text-align: center;
    padding: 40px 32px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
  }

  main .value-prop:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 32px rgba(0, 82, 217, 0.15);
  }

  main .value-prop-icon {
    width: 72px;
    height: 72px;
    background: linear-gradient(135deg, #0052D9 0%, #003CAB 100%);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
  }

  main .value-prop-icon svg {
    width: 36px;
    height: 36px;
    color: #fff;
  }

  main .value-prop-title {
    font-size: 24px;
    font-weight: 700;
    color: #181B25;
    margin-bottom: 16px;
  }

  main .value-prop-description {
    font-size: 15px;
    color: #5F646C;
    line-height: 1.7;
  }

  main .software-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  main .software-card {
    background: #fff;
    border: 1px solid #E3E6EB;
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    transition: all 0.3s ease;
  }

  main .software-card:hover {
    border-color: #0052D9;
    box-shadow: 0 8px 24px rgba(0, 82, 217, 0.1);
  }

  main .software-main {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
  }

  main .software-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, #E8F0FE 0%, #D4E4FC 100%);
