---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogPageDecor from '../../components/blog/BlogPageDecor.astro';
import { getTranslations, getBasePath } from '../../i18n/utils';
import { DEFAULT_LOCALE, SUPPORTED_LOCALES } from '../../i18n/config';
import '../../styles/global.css';

interface Props {
  /** UI locale for header/footer; article body is English until translated per locale. */
  lang?: string;
}

const { lang: langProp } = Astro.props;
const lang = langProp ?? 'en';
const translations = getTranslations(lang);
const basePath = getBasePath(lang);
const isDe = lang === 'de';
const title = isDe
  ? '1Panel vs Webmin: Open-Source-Kontrollpanel-Vergleich (2026)'
  : '1Panel vs Webmin: Open-Source Control Panel Comparison (2026)';
const description = isDe
  ? 'Praktischer Vergleich von 1Panel und Webmin: Architektur, Deployment, Sicherheit, Effizienz und Team-Passung.'
  : 'A practical comparison of 1Panel and Webmin across architecture, deployment workflow, security model, operations efficiency, and team fit.';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const pagePath = '/1panel-vs-webmin';
const hreflangLinks = SUPPORTED_LOCALES.map((locale) => ({
  hreflang: locale === 'zh-hant' ? 'zh-Hant' : locale,
  href: new URL(locale === DEFAULT_LOCALE ? pagePath : `/${locale}${pagePath}`, Astro.site).href,
}));
const xDefaultHref = new URL(pagePath, Astro.site).href;
const keywords = isDe
  ? '1Panel vs Webmin,Webmin Alternative,Linux Panel,Container,Self-Hosting'
  : '1Panel vs Webmin,Webmin alternative,open source server control panel,containerized server management,linux admin panel';

const faqEn = [
  {
    q: 'What is the biggest difference between 1Panel and Webmin?',
    a: '1Panel is app-centric and container-oriented, while Webmin is system-centric and focused on deep OS/service administration.',
  },
  {
    q: 'Which one is better for modern self-hosted app delivery?',
    a: '1Panel is usually better for modern app delivery because it aligns with containerized workflows and faster one-click operations.',
  },
  {
    q: 'Which one is better for deep Linux system administration?',
    a: 'Webmin is stronger when you need low-level system control, service-by-service tuning, and direct host-level operations.',
  },
  {
    q: 'Can teams use both 1Panel and Webmin together?',
    a: 'Yes. Some teams use 1Panel for application lifecycle and web delivery, while using Webmin for specialized host-level administration tasks.',
  },
];

const faqDe = [
  {
    q: 'Was ist der größte Unterschied zwischen 1Panel und Webmin?',
    a: '1Panel ist app- und containerorientiert, Webmin systemorientiert mit Fokus auf tiefe OS-/Dienstadministration.',
  },
  {
    q: 'Was ist besser für moderne Self-Hosted-App-Lieferung?',
    a: '1Panel passt meist besser zu Container-Workflows und schnelleren Ein-Klick-Abläufen.',
  },
  {
    q: 'Was ist besser für tiefe Linux-Administration?',
    a: 'Webmin ist stärker bei Low-Level-Kontrolle, Dienst-für-Dienst-Tuning und direkten Host-Operationen.',
  },
  {
    q: 'Können Teams beide parallel nutzen?',
    a: 'Ja: 1Panel für Anwendungslebenszyklus und Web, Webmin für spezialisierte Host-Administration.',
  },
];

const faq = isDe ? faqDe : faqEn;

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
};
const h1Headline = isDe
  ? '1Panel vs Webmin: App-zentriert vs systemzentrierte Administration'
  : '1Panel vs Webmin: App-Centric Ops vs System-Centric Administration';
const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  headline: h1Headline,
  description,
  inLanguage: lang,
  url: canonicalUrl,
};
---

<Layout
  title={title}
  description={description}
  lang={lang}
  basePath={basePath}
  canonicalUrl={canonicalUrl}
  keywords={keywords}
>
  <Fragment slot="head">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    {hreflangLinks.map((item) => <link rel="alternate" hreflang={item.hreflang} href={item.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </Fragment>

  <Fragment slot="main">
    <Header lang={lang} basePath={basePath} translations={translations} />
    <main class="relative z-10 min-h-screen compare-page">
      <div class="relative overflow-hidden bg-gradient-to-br from-slate-50 via-white to-indigo-50/40">
        <BlogPageDecor />
        <section class="section-padding relative z-10">
          <div class="container-custom max-w-5xl space-y-12">
            <header class="text-center">
              {isDe ? (
                <>
                  <h1 class="text-4xl lg:text-5xl font-extrabold text-slate-900 tracking-tight mb-6">
                    1Panel vs Webmin:
                    <span class="block text-indigo-600">App-zentriert vs systemzentrierte Administration</span>
                  </h1>
                  <p class="text-lg text-slate-600 max-w-3xl mx-auto leading-relaxed mb-8">
                    Beide sind leistungsstarke Open-Source-Tools mit unterschiedlichem Fokus — der ausführliche Vergleich folgt unten auf Englisch.
                  </p>
                  <div class="flex flex-col sm:flex-row justify-center gap-4">
                    <a href="#recommendation" class="compare-btn-primary">Empfehlung</a>
                    <a href="#matrix" class="compare-btn-secondary">Detailmatrix</a>
                  </div>
                </>
              ) : (
                <>
                  <h1 class="text-4xl lg:text-5xl font-extrabold text-slate-900 tracking-tight mb-6">
                    1Panel vs Webmin:
                    <span class="block text-indigo-600">App-Centric Ops vs System-Centric Administration</span>
                  </h1>
                  <p class="text-lg text-slate-600 max-w-3xl mx-auto leading-relaxed mb-8">
                    Both are powerful open-source tools, but they solve different problems. This page helps you choose the right control plane
                    for your next 12-24 months of infrastructure growth.
                  </p>
                  <div class="flex flex-col sm:flex-row justify-center gap-4">
                    <a href="#recommendation" class="compare-btn-primary">See Recommendation</a>
                    <a href="#matrix" class="compare-btn-secondary">View Detailed Matrix</a>
                  </div>
                </>
              )}
            </header>

            <section class="card p-6 sm:p-8">
              <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-5 mb-5">
                <div>
                  <h2 class="text-2xl font-bold text-slate-900">
                    {isDe ? 'Schnellvergleich: 1Panel vs Webmin' : 'Quick Feature Comparison: 1Panel vs Webmin'}
                  </h2>
                  <p class="text-slate-600 mt-2">
                    {isDe
                      ? 'Schneller Überblick, ob App-Delivery oder System-Administration im Vordergrund steht.'
                      : 'Fast snapshot to decide whether app delivery or deep host administration matters more.'}
                  </p>
                </div>
                <a href="./pricing" class="compare-btn-primary whitespace-nowrap">Start Migration</a>
              </div>
              <div class="overflow-x-auto rounded-xl border border-slate-200">
                <table class="w-full min-w-[520px] text-left text-sm text-slate-700">
                  <thead class="bg-slate-50 text-slate-900 font-semibold">
                    <tr>
                      <th class="px-4 py-3">Key Dimension</th>
                      <th class="px-4 py-3">1Panel</th>
                      <th class="px-4 py-3">Webmin</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-200">
                    <tr>
                      <td class="px-4 py-3 font-medium">Primary Focus</td>
                      <td class="px-4 py-3">Application lifecycle and delivery speed</td>
                      <td class="px-4 py-3">Deep host-level Linux control</td>
                    </tr>
                    <tr>
                      <td class="px-4 py-3 font-medium">Team Fit</td>
                      <td class="px-4 py-3">Developer and product teams</td>
                      <td class="px-4 py-3">System administrator heavy teams</td>
                    </tr>
                    <tr>
                      <td class="px-4 py-3 font-medium">AI Tooling</td>
                      <td class="px-4 py-3">Built-in AI and MCP workflow support</td>
                      <td class="px-4 py-3">Requires external AI setup</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </section>

            {isDe && (
              <p class="rounded-lg border border-amber-200 bg-amber-50/90 px-4 py-3 text-sm text-slate-700 text-center max-w-3xl mx-auto">
                Hinweis: Der ausführliche Vergleichstext auf dieser Seite ist derzeit auf Englisch. Kopf- und Fußzeile sind auf Deutsch.
              </p>
            )}

            <section id="overview" class="scroll-mt-24">
              <div class="card p-6 sm:p-8">
                <h2 class="text-2xl font-bold text-slate-900 mb-5">Executive Summary</h2>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-center">
                  <div class="compare-radar-wrap">
                    <canvas id="overviewRadarChart"></canvas>
                  </div>
                  <div>
                    <ul class="space-y-3 text-slate-700 leading-relaxed">
                      <li><strong>1Panel</strong> is usually the better default for modern self-hosted delivery: faster deployment workflow, cleaner container isolation, and simpler day-2 operations.</li>
                      <li><strong>Webmin</strong> is usually stronger for deep host-level administration where you need granular control over Linux services and system internals.</li>
                      <li>For most product teams, 1Panel improves delivery efficiency. For classic sysadmin-heavy environments, Webmin remains highly valuable.</li>
                    </ul>
                  </div>
                </div>
              </div>
            </section>

            <section class="card p-6 sm:p-8">
              <h2 class="text-2xl font-bold text-slate-900 mb-4">Architecture and Operations Model</h2>
              <div class="space-y-4 text-slate-700 leading-relaxed">
                <p>
                  1Panel is designed around a modern app lifecycle mindset: deploy apps quickly, isolate workloads through container-friendly operations,
                  and keep common infrastructure tasks unified in one interface.
                </p>
                <p>
                  Webmin is built around direct host/service administration. It excels when administrators need precision control over OS internals, service
                  configuration files, and traditional Linux operational depth.
                </p>
              </div>
            </section>

            <section class="card p-6 sm:p-8">
              <h2 class="text-2xl font-bold text-slate-900 mb-4">Deployment Efficiency Snapshot</h2>
              <p class="text-slate-700 leading-relaxed mb-5">
                This chart illustrates relative operational effort for a typical modern setup task (web service + data service + reverse proxy path), based on
                representative workflow complexity rather than exact benchmark timing.
              </p>
              <div class="compare-efficiency-chart-wrap">
                <canvas id="efficiencyChart"></canvas>
              </div>
            </section>

            <section class="card p-6 sm:p-8 border-indigo-200 bg-gradient-to-br from-indigo-50/60 to-white">
              <h2 class="text-2xl font-bold text-slate-900 mb-4">Security and Control Philosophy</h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="rounded-xl border border-indigo-200 bg-white p-5">
                  <h3 class="text-lg font-semibold text-slate-900 mb-2">1Panel Focus</h3>
                  <p class="text-slate-700 leading-relaxed">
                    Strong for application-level security workflows and service isolation patterns in modern self-hosted stacks.
                  </p>
                </div>
                <div class="rounded-xl border border-teal-200 bg-white p-5">
                  <h3 class="text-lg font-semibold text-slate-900 mb-2">Webmin Focus</h3>
                  <p class="text-slate-700 leading-relaxed">
                    Strong for host-level administration, permission granularity, and deep service control in traditional Linux operations.
                  </p>
                </div>
              </div>
            </section>

            <section id="ai-capabilities" class="card p-6 sm:p-8 scroll-mt-24">
              <h2 class="text-2xl font-bold text-slate-900 mb-6">AI Capabilities: A Key Differentiator</h2>
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <div>
                  <h3 class="text-lg font-semibold text-slate-900 mb-3">1Panel AI Features</h3>
                  <p class="text-slate-700 leading-relaxed mb-4">
                    1Panel ships with first-class AI infrastructure tooling that Webmin does not offer:
                  </p>
                  <ul class="space-y-3 text-slate-700 leading-relaxed list-disc pl-5">
                    <li>
                      <strong>Ollama integration</strong> — deploy and manage local LLMs (DeepSeek, Qwen, Llama 3) directly from the App Store
                    </li>
                    <li>
                      <strong>OpenClaw agents</strong> — run personal AI assistants with multi-channel support (Telegram, Slack, WhatsApp, Discord)
                    </li>
                    <li>
                      <strong>MCP Servers</strong> — connect AI agents to your server operations via Model Context Protocol
                    </li>
                    <li>
                      <strong>AI Terminal</strong> — convert natural language into executable shell commands (v2.1.6+)
                    </li>
                    <li>
                      <strong>GPU Monitoring</strong> — real-time GPU utilization dashboards for AI workloads
                    </li>
                    <li>
                      <strong>vLLM support</strong> — production-grade LLM inference server management
                    </li>
                  </ul>
                </div>
                <div>
                  <h3 class="text-lg font-semibold text-slate-900 mb-3">Webmin AI Features</h3>
                  <p class="text-slate-700 leading-relaxed">
                    Webmin does not include native AI tooling. Running LLMs or AI agents on a Webmin-managed server requires entirely separate setup and management outside the panel.
                  </p>
                </div>
              </div>
              <p class="mt-6 text-slate-800 leading-relaxed">
                <strong>Verdict:</strong> If AI infrastructure is on your roadmap, 1Panel has a clear, built-in advantage.
              </p>
            </section>

            <section id="pricing-comparison" class="card p-6 sm:p-8 scroll-mt-24">
              <h2 class="text-2xl font-bold text-slate-900 mb-6">Pricing Comparison</h2>
              <div class="overflow-x-auto -mx-2 px-2">
                <table class="compare-pricing-table w-full min-w-[520px] text-sm text-left border-collapse">
                  <thead>
                    <tr class="border-b border-slate-200 bg-slate-50">
                      <th class="py-3 px-3 font-semibold text-slate-900"></th>
                      <th class="py-3 px-3 font-semibold text-slate-900">Webmin</th>
                      <th class="py-3 px-3 font-semibold text-slate-900">1Panel OSS</th>
                      <th class="py-3 px-3 font-semibold text-slate-900">1Panel Pro</th>
                    </tr>
                  </thead>
                  <tbody class="text-slate-700">
                    <tr class="border-b border-slate-100">
                      <td class="py-3 px-3 font-medium text-slate-900">License</td>
                      <td class="py-3 px-3">Free (GPL)</td>
                      <td class="py-3 px-3">Free (GPL)</td>
                      <td class="py-3 px-3">$80/year or $200 perpetual</td>
                    </tr>
                    <tr class="border-b border-slate-100 bg-slate-50/50">
                      <td class="py-3 px-3 font-medium text-slate-900">Core features</td>
                      <td class="py-3 px-3">✓</td>
                      <td class="py-3 px-3">✓</td>
                      <td class="py-3 px-3">✓</td>
                    </tr>
                    <tr class="border-b border-slate-100">
                      <td class="py-3 px-3 font-medium text-slate-900">AI / LLM management</td>
                      <td class="py-3 px-3">✗</td>
                      <td class="py-3 px-3">Partial</td>
                      <td class="py-3 px-3">✓ Unlimited</td>
                    </tr>
                    <tr class="border-b border-slate-100 bg-slate-50/50">
                      <td class="py-3 px-3 font-medium text-slate-900">Multi-node management</td>
                      <td class="py-3 px-3">✗</td>
                      <td class="py-3 px-3">✗</td>
                      <td class="py-3 px-3">✓</td>
                    </tr>
                    <tr class="border-b border-slate-100">
                      <td class="py-3 px-3 font-medium text-slate-900">WAF Firewall</td>
                      <td class="py-3 px-3">✗</td>
                      <td class="py-3 px-3">Basic</td>
                      <td class="py-3 px-3">✓ Full</td>
                    </tr>
                    <tr class="border-b border-slate-100 bg-slate-50/50">
                      <td class="py-3 px-3 font-medium text-slate-900">Mobile app (iOS/Android)</td>
                      <td class="py-3 px-3">✗</td>
                      <td class="py-3 px-3">✗</td>
                      <td class="py-3 px-3">✓</td>
                    </tr>
                    <tr class="border-b border-slate-200">
                      <td class="py-3 px-3 font-medium text-slate-900">Priority support</td>
                      <td class="py-3 px-3">✗</td>
                      <td class="py-3 px-3">✗</td>
                      <td class="py-3 px-3">✓</td>
                    </tr>
                  </tbody>
                </table>
              </div>
              <p class="mt-5 text-slate-700 leading-relaxed">
                For most self-hosted use cases, 1Panel OSS is completely free with no feature limits on core operations. Pro is for teams who need advanced AI quotas, security, and multi-server management.
              </p>
              <a
                href={`${basePath}pricing`}
                class="inline-flex items-center mt-4 font-semibold text-indigo-600 hover:text-indigo-700 transition"
              >
                Compare all plans →
              </a>
            </section>

            <section id="matrix" class="scroll-mt-24">
              <div class="text-center mb-8">
                <h2 class="text-3xl font-bold text-slate-900 mb-3">Detailed Comparison Matrix</h2>
                <p class="text-slate-600 max-w-3xl mx-auto">
                  Compare practical trade-offs across architecture, UX model, and operations depth.
                </p>
              </div>
              <div class="card p-0 overflow-hidden">
                <div class="flex flex-wrap border-b border-slate-200" id="tabContainer">
                  <button class="compare-tab tab-active" data-target="tab-arch">Architecture</button>
                  <button class="compare-tab tab-inactive" data-target="tab-ux">UX</button>
                  <button class="compare-tab tab-inactive" data-target="tab-ops">Ops Depth</button>
                </div>
                <div class="p-6 md:p-8">
                  <div id="tab-arch" class="tab-panel section-fade-in">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                      <div class="compare-col compare-col-1p">
                        <h3 class="text-xl font-bold mb-3">1Panel Architecture</h3>
                        <p>Designed for modern app delivery with container-friendly operational patterns and cleaner environment boundaries.</p>
                      </div>
                      <div class="compare-col compare-col-wm">
                        <h3 class="text-xl font-bold mb-3">Webmin Architecture</h3>
                        <p>Built for direct Unix/Linux service control with deep module-based administration across core system capabilities.</p>
                      </div>
                    </div>
                  </div>
                  <div id="tab-ux" class="tab-panel hidden section-fade-in">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                      <div class="compare-col compare-col-1p">
                        <h3 class="text-xl font-bold mb-3">1Panel UX</h3>
                        <p>Workflow-first interface that reduces friction for developers and product teams operating self-hosted services.</p>
                      </div>
                      <div class="compare-col compare-col-wm">
                        <h3 class="text-xl font-bold mb-3">Webmin UX</h3>
                        <p>Feature-dense administration experience preferred by administrators who want explicit, fine-grained control.</p>
                      </div>
                    </div>
                  </div>
                  <div id="tab-ops" class="tab-panel hidden section-fade-in">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                      <div class="compare-col compare-col-1p">
                        <h3 class="text-xl font-bold mb-3">1Panel Ops Depth</h3>
                        <p>Excellent for application lifecycle speed, website operations, and growth from single-node to multi-node workflows.</p>
                      </div>
                      <div class="compare-col compare-col-wm">
                        <h3 class="text-xl font-bold mb-3">Webmin Ops Depth</h3>
                        <p>Excellent for advanced host-level service tuning, low-level troubleshooting, and classic sysadmin responsibilities.</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <section class="card p-6 sm:p-8">
              <h2 class="text-2xl font-bold text-gray-800 mb-4">FAQ</h2>
              <div class="space-y-4">
                {faq.map((item) => (
                  <details class="faq-item rounded-lg border border-gray-200 bg-white p-4">
                    <summary class="cursor-pointer font-semibold text-gray-800 pr-7">{item.q}</summary>
                    <p class="mt-3 text-gray-600">{item.a}</p>
                  </details>
                ))}
              </div>
            </section>

            <section id="recommendation" class="card p-8 md:p-10 bg-gradient-to-br from-indigo-900 to-indigo-700 text-white">
              <h2 class="text-3xl font-extrabold mb-4">Final Recommendation</h2>
              <p class="text-indigo-100 text-lg leading-relaxed mb-6">
                For most modern product and growth teams, 1Panel is the more practical default because it aligns with app-centric operations.
                Choose Webmin when your primary requirement is deep host-level Linux administration and system service control.
              </p>
              <a href="./pricing" class="inline-flex items-center px-7 py-3 rounded-lg bg-white text-indigo-800 font-semibold hover:bg-indigo-50 transition">
                Compare 1Panel Plans
              </a>
            </section>
          </div>
        </section>
      </div>
    </main>
    <Footer lang={lang} basePath={basePath} translations={translations} />
  </Fragment>
</Layout>

<style>
  main {
    position: relative;
    z-index: 1;
  }

  .compare-page {
    overflow-x: hidden;
  }

  :global(html),
  :global(body) {
    overflow-x: hidden;
  }

  .compare-btn-primary {
    @apply inline-flex items-center justify-center px-6 py-3 rounded-lg text-white font-medium shadow-sm transition;
    background: linear-gradient(135deg, #4f46e5 0%, #005eeb 100%);
  }

  .compare-btn-primary:hover {
    @apply shadow-lg;
  }

  .compare-btn-secondary {
    @apply inline-flex items-center justify-center px-6 py-3 rounded-lg border border-slate-300 text-slate-700 bg-white font-medium transition;
  }

  .compare-btn-secondary:hover {
    @apply bg-slate-50;
  }

  .compare-tab {
    @apply flex-1 min-w-[160px] py-4 px-6 text-center font-medium transition border-b-2;
  }

  .tab-active {
    border-bottom-color: #4f46e5;
    color: #4f46e5;
    font-weight: 700;
  }

  .tab-inactive {
    border-bottom-color: transparent;
    color: #64748b;
  }

  .tab-inactive:hover {
    color: #334155;
    border-bottom-color: #cbd5e1;
  }

  .compare-col {
    @apply rounded-xl p-5 border;
  }

  .compare-col p {
    @apply text-slate-700 leading-relaxed;
  }

  .compare-col-1p {
    @apply bg-indigo-50 border-indigo-100 text-indigo-900;
  }

  .compare-col-wm {
    @apply bg-teal-50 border-teal-100 text-teal-900;
  }

  .compare-radar-wrap {
    position: relative;
    width: 100%;
    max-width: 430px;
    margin: 0 auto;
    height: 360px;
  }

  .compare-efficiency-chart-wrap {
    position: relative;
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
    height: 280px;
  }

  @media (max-width: 767px) {
    .compare-radar-wrap {
      height: 320px;
    }

    .compare-efficiency-chart-wrap {
      height: 260px;
    }
  }

  .section-fade-in {
    animation: fadeIn 0.4s ease-in-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .faq-item summary {
    list-style: none;
    position: relative;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: "+";
    position: absolute;
    right: 0;
    top: 0;
    color: #005eeb;
    font-weight: 700;
  }

  .faq-item[open] summary::after {
    content: "-";
  }
</style>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Chart !== 'undefined') {
      const radar = document.getElementById('overviewRadarChart');
      if (radar) {
        new Chart(radar, {
          type: 'radar',
          data: {
            labels: ['Modern UX', 'App Deployment Speed', 'Container Alignment', 'Deep OS Control', 'Legacy Admin Fit'],
            datasets: [
              {
                label: '1Panel',
                data: [95, 96, 94, 45, 55],
                backgroundColor: 'rgba(79, 70, 229, 0.20)',
                borderColor: 'rgba(79, 70, 229, 1)',
                pointBackgroundColor: 'rgba(79, 70, 229, 1)',
                borderWidth: 2,
              },
              {
                label: 'Webmin',
                data: [58, 52, 48, 96, 92],
                backgroundColor: 'rgba(13, 148, 136, 0.20)',
                borderColor: 'rgba(13, 148, 136, 1)',
                pointBackgroundColor: 'rgba(13, 148, 136, 1)',
                borderWidth: 2,
              },
            ],
          },
          options: {
            maintainAspectRatio: false,
            scales: {
              r: {
                min: 0,
                max: 100,
                ticks: { display: false },
                grid: { color: 'rgba(15, 23, 42, 0.10)' },
                pointLabels: { color: '#475569', font: { size: 12 } },
              },
            },
            plugins: {
              legend: { position: 'bottom' },
            },
          },
        });
      }

      const efficiency = document.getElementById('efficiencyChart');
      if (efficiency) {
        new Chart(efficiency, {
          type: 'bar',
          data: {
            labels: ['Estimated setup time (minutes)', 'Operation touchpoints'],
            datasets: [
              {
                label: '1Panel',
                data: [4, 5],
                backgroundColor: 'rgba(79, 70, 229, 0.85)',
                borderRadius: 6,
              },
              {
                label: 'Webmin',
                data: [20, 14],
                backgroundColor: 'rgba(13, 148, 136, 0.85)',
                borderRadius: 6,
              },
            ],
          },
          options: {
            indexAxis: 'y',
            maintainAspectRatio: false,
            scales: {
              x: { beginAtZero: true, grid: { color: 'rgba(15,23,42,.06)' } },
              y: { grid: { display: false } },
            },
            plugins: {
              legend: { position: 'bottom' },
            },
          },
        });
      }
    }

    const tabs = document.querySelectorAll('#tabContainer button');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => {
          t.classList.remove('tab-active');
          t.classList.add('tab-inactive');
        });
        tab.classList.remove('tab-inactive');
        tab.classList.add('tab-active');

        document.querySelectorAll('.tab-panel').forEach((p) => p.classList.add('hidden'));
        const targetId = tab.getAttribute('data-target');
        if (!targetId) return;
        const panel = document.getElementById(targetId);
        if (panel) panel.classList.remove('hidden');
      });
    });
  });
</script>
