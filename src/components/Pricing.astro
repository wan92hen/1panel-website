---
import { Icon } from 'astro-icon/components';
import { t, getTranslations } from '../i18n/utils';
import type { TranslationDict } from '../i18n/utils';
import { DEFAULT_LOCALE } from '../i18n/config';

interface Props {
  lang?: string;
  basePath?: string;
  translations?: TranslationDict;
}

const { lang: rawLang, translations: rawTranslations } = Astro.props;
const lang = rawLang ?? DEFAULT_LOCALE;
const translations =
  rawTranslations && Object.keys(rawTranslations || {}).length > 0
    ? rawTranslations!
    : getTranslations('en');
const enT = getTranslations('en');

/** New pricing copy lives in en.json; other locales fall back to English until translated. */
function tr(path: string): string {
  const localized = t(translations, path);
  if (localized !== path) return localized;
  return t(enT, path);
}

/** 30-day Pro trial — email Lxware (forms e.g. Tally can replace this later). */
const trialMailto = `mailto:hi@lxware.hk?subject=${encodeURIComponent('1Panel Pro: 30-Day Free Trial Request')}`;
const docsBase = 'https://1panel.pro/docs';
const nodeDocsUrl = `${docsBase}/v2/user_manual/xpack/node/`;
const installUrl = `${docsBase}/v2/installation/online_installation/`;
const subBuyUrl =
  'https://www.lxware.hk/products/1panel-pro-edition-subscription-license';
const perpBuyUrl = 'https://www.lxware.hk/products/1panel-professional-edition';
const lxwareUrl = 'https://lxware.hk';
const enterpriseMail =
  'mailto:hi@lxware.hk?subject=' +
  encodeURIComponent('1Panel Enterprise / Volume Pricing');
---

<section id="pricing" class="section-padding bg-gradient-to-br from-gray-50 to-white">
  <div class="container-custom">
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="fade-in-up text-4xl lg:text-5xl font-bold text-gray-800 mb-6">
        {t(translations, 'pricing.title')}
        <span class="text-1panel-gradient">{t(translations, 'pricing.titleHighlight')}</span>
      </h2>
      <p class="fade-in-up text-xl text-gray-600 max-w-3xl mx-auto" style="animation-delay: 0.2s;">
        {t(translations, 'pricing.subtitle')}
      </p>
    </div>

    <!-- Social proof bar -->
    <div
      class="max-w-5xl mx-auto mb-10 rounded-xl border border-white/[0.07] bg-slate-950 px-4 py-4 sm:px-8 sm:py-5 shadow-lg"
      style="background-image: linear-gradient(rgba(255,255,255,0.03), rgba(255,255,255,0.03));"
    >
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3 text-sm sm:text-[13.5px] text-slate-400">
        <div class="flex items-center gap-2">
          <span class="font-mono font-semibold text-white tabular-nums">{tr('pricing.proof.installNum')}</span>
          <span class="text-slate-400">{tr('pricing.proof.installLabel')}</span>
        </div>
        <span class="hidden sm:inline text-slate-600" aria-hidden="true">·</span>
        <div class="flex items-center gap-2">
          <span class="font-mono font-semibold text-white tabular-nums">{tr('pricing.proof.teamsNum')}</span>
          <span class="text-slate-400">{tr('pricing.proof.teamsLabel')}</span>
        </div>
        <span class="hidden sm:inline text-slate-600" aria-hidden="true">·</span>
        <div class="flex items-center gap-2">
          <span class="font-mono font-semibold text-white tabular-nums">{tr('pricing.proof.ratingNum')}</span>
          <span class="text-slate-400">{tr('pricing.proof.ratingLabel')}</span>
        </div>
        <span class="hidden sm:inline text-slate-600" aria-hidden="true">·</span>
        <div class="flex items-center gap-2">
          <span class="font-mono font-semibold text-white tabular-nums">{tr('pricing.proof.trialNum')}</span>
          <span class="text-slate-400">{tr('pricing.proof.trialLabel')}</span>
        </div>
      </div>
    </div>

    <!-- Trial banner -->
    <div
      class="max-w-5xl mx-auto mb-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 rounded-xl border border-gray-200 bg-gray-100/80 px-4 py-4 sm:px-6"
    >
      <p class="text-sm sm:text-[15px] text-gray-800 text-left leading-relaxed flex-1">
        {tr('pricing.trialBanner.text')}
      </p>
      <a
        href={trialMailto}
        class="shrink-0 inline-flex justify-center items-center px-5 py-2.5 rounded-lg bg-1panel text-white font-semibold text-sm hover:opacity-90 transition-opacity"
      >
        {tr('pricing.trialBanner.cta')}
      </a>
    </div>

    <!-- Plan cards: OSS | Subscription (featured) | Perpetual -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 max-w-7xl mx-auto relative items-stretch">
      <!-- OSS -->
      <div
        class="fade-in-up card group hover:shadow-xl transition-shadow duration-300 flex flex-col h-full"
        style="animation-delay: 0.3s;"
      >
        <div class="p-6 flex flex-col flex-1">
          <div class="text-center mb-4">
            <div class="flex items-center justify-center gap-2 text-gray-500 text-sm font-medium mb-2">
              <Icon name="carbon:logo-github" class="w-5 h-5 shrink-0" />
              <span>{t(translations, 'pricing.ossEdition')}</span>
            </div>
            <h3 class="text-2xl font-bold text-gray-800 mb-1">{t(translations, 'pricing.freeToUse')}</h3>
            <div class="text-4xl font-bold text-gray-900 my-3">$0</div>
            <p class="text-sm text-gray-600 min-h-[2.5rem]">{tr('pricing.ossCardDesc')}</p>
          </div>
          <hr class="border-gray-200 my-4" />
          <ul class="space-y-3 mb-6 text-left flex-1 text-sm text-gray-800">
            {['b1', 'b2', 'b3', 'b4', 'b5', 'b6', 'b7'].map((k) => (
              <li class="flex gap-2">
                <Icon name="mdi:check" class="w-5 h-5 text-gray-500 shrink-0 mt-0.5" />
                <span>{tr(`pricing.ossBullets.${k}`)}</span>
              </li>
            ))}
          </ul>
          <a
            href={installUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full inline-flex justify-center items-center px-6 py-3 rounded-lg border border-gray-200 text-gray-700 font-medium hover:bg-gray-50 transition-colors"
          >
            {t(translations, 'pricing.quickStart')}
          </a>
        </div>
      </div>

      <!-- Subscription — Most Popular -->
      <div
        class="fade-in-up relative rounded-xl border-2 border-1panel/35 bg-white shadow-xl shadow-gray-900/5 flex flex-col h-full lg:scale-[1.02] z-[1]"
        style="animation-delay: 0.4s;"
      >
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 z-10">
          <span class="bg-1panel text-white px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wide shadow-md whitespace-nowrap">
            {t(translations, 'pricing.mostPopular')}
          </span>
        </div>
        <div class="p-6 pt-8 flex flex-col flex-1">
          <div class="text-center mb-4">
            <div class="flex items-center justify-center gap-2 text-gray-500 text-sm font-medium mb-2">
              <Icon name="mdi:diamond-stone" class="w-5 h-5 text-gray-400 shrink-0" />
              <span>{t(translations, 'pricing.proEdition')}</span>
            </div>
            <h3 class="text-2xl font-bold text-gray-800 mb-1">{t(translations, 'pricing.subscriptionLicense')}</h3>
            <div class="flex items-baseline justify-center gap-1 my-3">
              <span class="text-5xl font-bold text-gray-900">$80</span>
              <span class="text-gray-500 text-sm">/ year</span>
            </div>
            <p class="text-sm text-gray-600 min-h-[2.5rem]">{tr('pricing.subscriptionCardDesc')}</p>
          </div>
          <hr class="border-gray-200 my-4" />
          <ul class="space-y-3 mb-4 text-left flex-1 text-sm text-gray-800">
            {['b1', 'b2', 'b3', 'b4', 'b5', 'b6', 'b7', 'b8', 'b9'].map((k, idx) => (
              <li class="flex gap-2">
                {idx === 0 || idx >= 7 ? (
                  <Icon name="mdi:check" class="w-5 h-5 text-gray-500 shrink-0 mt-0.5" />
                ) : (
                  <span class="text-gray-400 shrink-0 mt-0.5" aria-hidden="true">★</span>
                )}
                <span set:html={tr(`pricing.subBullets.${k}`)} />
              </li>
            ))}
          </ul>
          <a
            href={subBuyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="buy-subscription-license-button w-full inline-flex justify-center items-center px-6 py-3 bg-1panel text-white rounded-lg font-semibold hover:opacity-90 transition-opacity"
          >
            {tr('pricing.buySubscriptionCta')}
          </a>
          <a
            href={trialMailto}
            class="w-full mt-2 inline-flex justify-center items-center px-6 py-3 rounded-lg border border-gray-200 text-gray-600 font-medium hover:bg-gray-50 transition-colors text-sm"
          >
            {tr('pricing.tryFreeCta')}
          </a>
          <p
            class="text-[11px] text-center text-gray-500 mt-3 leading-snug"
            set:html={tr('pricing.trustLxwareLine').replace(
              '{{lxware}}',
              `<a href="${lxwareUrl}" class="text-1panel hover:underline" target="_blank" rel="noopener noreferrer">Lxware</a>`,
            )}
          />
        </div>
      </div>

      <!-- Perpetual — Best value -->
      <div
        class="fade-in-up card group hover:shadow-xl transition-shadow duration-300 flex flex-col h-full relative"
        style="animation-delay: 0.5s;"
      >
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 z-10">
          <span class="bg-gray-100 text-gray-700 border border-gray-200 px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-wide whitespace-nowrap">
            {tr('pricing.bestValueLongTerm')}
          </span>
        </div>
        <div class="p-6 pt-8 flex flex-col flex-1">
          <div class="text-center mb-4">
            <div class="flex items-center justify-center gap-2 text-gray-500 text-sm font-medium mb-2">
              <Icon name="mdi:diamond-stone" class="w-5 h-5 text-gray-400 shrink-0" />
              <span>{t(translations, 'pricing.proEdition')}</span>
            </div>
            <h3 class="text-2xl font-bold text-gray-800 mb-1">{t(translations, 'pricing.perpetualLicense')}</h3>
            <div class="flex items-baseline justify-center gap-1 my-3">
              <span class="text-5xl font-bold text-gray-900">$200</span>
              <span class="text-gray-500 text-sm">/ license</span>
            </div>
            <p class="text-sm text-gray-600 min-h-[2.5rem]">{tr('pricing.perpetualCardDesc')}</p>
          </div>

          <div
            class="text-[11px] text-gray-700 bg-gray-100 border border-gray-200 rounded-lg px-3 py-2 mb-4 leading-relaxed"
            role="note"
          >
            📌 {tr('pricing.perpetualVersionNote')}
          </div>

          <ul class="space-y-3 mb-4 text-left flex-1 text-sm text-gray-800">
            {['b1', 'b2', 'b3', 'b4', 'b5', 'b6', 'b7', 'b8', 'b9'].map((k, idx) => (
              <li class="flex gap-2">
                {idx === 0 || idx >= 7 ? (
                  <Icon name="mdi:check" class="w-5 h-5 text-gray-500 shrink-0 mt-0.5" />
                ) : (
                  <span class="text-gray-400 shrink-0 mt-0.5" aria-hidden="true">◆</span>
                )}
                <span set:html={tr(`pricing.perpBullets.${k}`)} />
              </li>
            ))}
          </ul>
          <a
            href={perpBuyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="buy-perpetual-license-button w-full inline-flex justify-center items-center px-6 py-3 bg-gray-900 text-white rounded-lg font-semibold hover:bg-gray-800 transition-colors"
          >
            {tr('pricing.buyPerpetualCta')}
          </a>
          <a
            href={trialMailto}
            class="w-full mt-2 inline-flex justify-center items-center px-6 py-3 rounded-lg border border-gray-200 text-gray-600 font-medium hover:bg-gray-50 transition-colors text-sm"
          >
            {tr('pricing.tryFreeCta')}
          </a>
          <p
            class="text-[11px] text-center text-gray-500 mt-3 leading-snug"
            set:html={tr('pricing.trustLxwareLine').replace(
              '{{lxware}}',
              `<a href="${lxwareUrl}" class="text-1panel hover:underline" target="_blank" rel="noopener noreferrer">Lxware</a>`,
            )}
          />
        </div>
      </div>
    </div>

    <!-- Enterprise -->
    <div
      class="max-w-5xl mx-auto mt-10 mb-16 rounded-xl border border-dashed border-gray-300 bg-gray-50/80 px-5 py-5 text-center"
    >
      <p class="text-sm text-gray-700 mb-2" set:html={tr('pricing.enterprisePrompt').replace('10+', '<strong>10+</strong>')} />
      <a
        href={enterpriseMail}
        class="text-1panel font-semibold text-sm hover:underline inline-flex items-center gap-1"
      >
        {tr('pricing.enterpriseCta')}
      </a>
    </div>

    <!-- Pro value highlights -->
    <div
      class="max-w-6xl mx-auto mb-14 rounded-2xl border border-gray-200 bg-gray-50 px-5 py-8 sm:px-8"
    >
      <h3 class="text-lg font-semibold text-gray-900 mb-6 flex items-center gap-2">
        <span aria-hidden="true">⚡</span>
        {tr('pricing.proValueTitle')}
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <div class="flex gap-3 rounded-xl bg-white/60 border border-gray-100 p-4">
          <span class="text-xl shrink-0" aria-hidden="true">🤖</span>
          <div>
            <strong class="block text-gray-900 text-sm">{tr('pricing.proValueAiTitle')}</strong>
            <span class="text-xs text-gray-600 leading-relaxed">{tr('pricing.proValueAiDesc')}</span>
          </div>
        </div>
        <div class="flex gap-3 rounded-xl bg-white/60 border border-gray-100 p-4">
          <span class="text-xl shrink-0" aria-hidden="true">🖥</span>
          <div>
            <strong class="block text-gray-900 text-sm">{tr('pricing.proValueNodeTitle')}</strong>
            <span class="text-xs text-gray-600 leading-relaxed">{tr('pricing.proValueNodeDesc')}</span>
          </div>
        </div>
        <div class="flex gap-3 rounded-xl bg-white/60 border border-gray-100 p-4">
          <span class="text-xl shrink-0" aria-hidden="true">🔒</span>
          <div>
            <strong class="block text-gray-900 text-sm">{tr('pricing.proValueSecTitle')}</strong>
            <span class="text-xs text-gray-600 leading-relaxed">{tr('pricing.proValueSecDesc')}</span>
          </div>
        </div>
        <div class="flex gap-3 rounded-xl bg-white/60 border border-gray-100 p-4">
          <span class="text-xl shrink-0" aria-hidden="true">📱</span>
          <div>
            <strong class="block text-gray-900 text-sm">{tr('pricing.proValueMobileTitle')}</strong>
            <span class="text-xs text-gray-600 leading-relaxed">{tr('pricing.proValueMobileDesc')}</span>
          </div>
        </div>
        <div class="flex gap-3 rounded-xl bg-white/60 border border-gray-100 p-4 sm:col-span-2 lg:col-span-1">
          <span class="text-xl shrink-0" aria-hidden="true">🎨</span>
          <div>
            <strong class="block text-gray-900 text-sm">{tr('pricing.proValueWhiteLabelTitle')}</strong>
            <span class="text-xs text-gray-600 leading-relaxed">{tr('pricing.proValueWhiteLabelDesc')}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Comparison table (differences only) -->
    <div class="mt-4 mb-16">
      <div class="text-center mb-8 max-w-3xl mx-auto">
        <h3 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-3">{tr('pricing.compareTitle')}</h3>
        <p class="text-sm sm:text-base text-gray-600 leading-relaxed">{tr('pricing.compareIntro')}</p>
      </div>

      <div class="overflow-x-auto fade-in-up">
        <table class="w-full max-w-5xl mx-auto bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden feature-table text-sm mb-4">
          <thead>
            <tr class="bg-gray-100 border-b border-gray-200">
              <th class="px-4 py-3 text-left font-semibold text-gray-700 w-[50%]">Features</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-700 w-[25%]">OSS</th>
              <th class="px-4 py-3 text-center font-semibold text-gray-900 w-[25%]">Pro</th>
            </tr>
          </thead>
          <tbody>
            <tr class="bg-gray-100">
              <td colspan="3" class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-gray-600">
                {tr('pricing.compare.catAi')}
              </td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.openclaw')}</td>
              <td class="px-4 py-2.5 text-center">
                <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-gray-100 text-gray-700">{tr('pricing.compare.pillUpTo5')}</span>
              </td>
              <td class="px-4 py-2.5 text-center">
                <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-gray-200 text-gray-800">{tr('pricing.compare.pillUnlimited')}</span>
              </td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.mcp')}</td>
              <td class="px-4 py-2.5 text-center text-gray-400">—</td>
              <td class="px-4 py-2.5 text-center"><Icon name="mdi:check" class="w-5 h-5 text-gray-600 inline" /></td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.gpu')}</td>
              <td class="px-4 py-2.5 text-center text-gray-400">—</td>
              <td class="px-4 py-2.5 text-center"><Icon name="mdi:check" class="w-5 h-5 text-gray-600 inline" /></td>
            </tr>

            <tr class="bg-gray-100">
              <td colspan="3" class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-gray-600">{tr('pricing.compare.catWebsite')}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.webBackup')}</td>
              <td class="px-4 py-2.5 text-center text-gray-400">—</td>
              <td class="px-4 py-2.5 text-center"><Icon name="mdi:check" class="w-5 h-5 text-gray-600 inline" /></td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.webMonitor')}</td>
              <td class="px-4 py-2.5 text-center text-gray-400">—</td>
              <td class="px-4 py-2.5 text-center"><Icon name="mdi:check" class="w-5 h-5 text-gray-600 inline" /></td>
            </tr>

            <tr class="bg-gray-100">
              <td colspan="3" class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-gray-600">{tr('pricing.compare.catMulti')}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.multiConsole')}</td>
              <td class="px-4 py-2.5 text-center text-gray-400">—</td>
              <td class="px-4 py-2.5 text-center"><Icon name="mdi:check" class="w-5 h-5 text-gray-600 inline" /></td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.crossFile')}</td>
              <td class="px-4 py-2.5 text-center text-gray-400">—</td>
              <td class="px-4 py-2.5 text-center"><Icon name="mdi:check" class="w-5 h-5 text-gray-600 inline" /></td>
            </tr>

            <tr class="bg-gray-100">
              <td colspan="3" class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-gray-600">{tr('pricing.compare.catSecurity')}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.waf')}</td>
              <td class="px-4 py-2.5 text-center">
                <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-gray-100 text-gray-700">{tr('pricing.compare.pillBasic')}</span>
              </td>
              <td class="px-4 py-2.5 text-center">
                <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full bg-gray-200 text-gray-800">{tr('pricing.compare.pillAdvanced')}</span>
              </td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.antiTamper')}</td>
              <td class="px-4 py-2.5 text-center text-gray-400">—</td>
              <td class="px-4 py-2.5 text-center"><Icon name="mdi:check" class="w-5 h-5 text-gray-600 inline" /></td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.virus')}</td>
              <td class="px-4 py-2.5 text-center text-gray-400">—</td>
              <td class="px-4 py-2.5 text-center"><Icon name="mdi:check" class="w-5 h-5 text-gray-600 inline" /></td>
            </tr>

            <tr class="bg-gray-100">
              <td colspan="3" class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-gray-600">{tr('pricing.compare.catMobile')}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.mobileApps')}</td>
              <td class="px-4 py-2.5 text-center text-gray-400">—</td>
              <td class="px-4 py-2.5 text-center"><Icon name="mdi:check" class="w-5 h-5 text-gray-600 inline" /></td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.alerts')}</td>
              <td class="px-4 py-2.5 text-center text-gray-400">—</td>
              <td class="px-4 py-2.5 text-center"><Icon name="mdi:check" class="w-5 h-5 text-gray-600 inline" /></td>
            </tr>

            <tr class="bg-gray-100">
              <td colspan="3" class="px-4 py-2 text-xs font-bold uppercase tracking-wider text-gray-600">{tr('pricing.compare.catCustom')}</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-2.5 text-gray-800 font-medium">{tr('pricing.compare.customStore')}</td>
              <td class="px-4 py-2.5 text-center text-gray-400">—</td>
