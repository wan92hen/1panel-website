---
// Pricing section for 1Panel website
import { Icon } from 'astro-icon/components';
import { t, getTranslations } from '../i18n/utils';
import type { TranslationDict } from '../i18n/utils';

interface Props {
  lang?: string;
  basePath?: string;
  translations?: TranslationDict;
}

const { translations: rawTranslations } = Astro.props;
const translations = rawTranslations && Object.keys(rawTranslations || {}).length > 0 ? rawTranslations! : getTranslations('en');
---

<section id="pricing" class="section-padding bg-gradient-to-br from-gray-50 to-white">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <h2 class="fade-in-up text-4xl lg:text-5xl font-bold text-gray-800 mb-6">
        {t(translations, 'pricing.title')}
        <span class="text-1panel-gradient">{t(translations, 'pricing.titleHighlight')}</span>
      </h2>
      <p class="fade-in-up text-xl text-gray-600 max-w-3xl mx-auto" style="animation-delay: 0.2s;">
        {t(translations, 'pricing.subtitle')}
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto relative">
      
      <!-- OSS Edition -->
      <div class="fade-in-up card group hover:scale-105 transition-transform duration-300" style="animation-delay: 0.3s;">
        <div class="text-center p-4">
          <!-- Plan Header -->
          <div class="mb-6">
            <div class="flex items-center justify-center space-x-2 font-medium text-gray-500 mb-2">
              <Icon name="carbon:logo-github" class="w-5 h-5 flex-shrink-0" />
              <span>{t(translations, 'pricing.ossEdition')}</span>
            </div>
            <h3 class="text-2xl font-bold text-gray-800 mb-4">{t(translations, 'pricing.freeToUse')}</h3>
            <p class="text-gray-600">{t(translations, 'pricing.openSource')}</p>
          </div>

          <!-- Features -->
          <ul class="space-y-4 mb-8 text-left">
            <li class="flex items-center">
              <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
              <span class="text-gray-700">{t(translations, 'pricing.noCost')}</span>
            </li>
            <li class="flex items-center">
              <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
              <span class="text-gray-700">{t(translations, 'pricing.validated')}</span>
            </li>
            <li class="flex items-center">
              <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
              <span class="text-gray-700">{t(translations, 'pricing.communitySupport')}</span>
            </li>
          </ul>

          <!-- CTA Button -->
          <a 
            href="https://docs.1panel.pro/quick_start/" 
            target="_blank"
            class="w-full inline-flex justify-center items-center px-6 py-3 bg-gray-100 border border-gray-300 text-gray-700 rounded-lg font-medium transition-all duration-300 hover:bg-gray-200 hover:border-gray-400"
          >
            {t(translations, 'pricing.quickStart')}
          </a>
        </div>
      </div>

      <!-- Pro Edition - Perpetual -->
      <div class="fade-in-up card group hover:scale-105 transition-transform duration-300 relative transform scale-105" style="animation-delay: 0.4s;">
        <!-- Popular Badge -->
        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
          <span class="bg-1panel-gradient text-white px-4 py-2 rounded-full text-sm font-medium shadow-lg">
            {t(translations, 'pricing.mostPopular')}
          </span>
        </div>
        
        <div class="text-center p-4">
          <!-- Plan Header -->
          <div class="mb-6">
            <div class="flex items-center justify-center space-x-2 font-medium text-gray-500 mb-2">
              <Icon name="mdi:diamond-stone" class="w-5 h-5 text-yellow-500 flex-shrink-0" />
              <span>{t(translations, 'pricing.proEdition')}</span>
            </div>
            <h3 class="text-2xl font-bold text-gray-800 mb-4">{t(translations, 'pricing.perpetualLicense')}</h3>
            <div class="mb-6">
              <div class="flex items-baseline justify-center">
                <span class="text-5xl font-bold text-1panel">$200</span>
                <span class="text-gray-600 text-sm ml-2">/ per License</span>
              </div>
            </div>
          </div>

          <!-- Features -->
          <ul class="space-y-4 mb-8 text-left">
            <li class="flex items-center">
              <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
              <span class="text-gray-700">All features of OSS Edition</span>
            </li>
            <li class="flex items-center">
              <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
              <span class="text-gray-700">Enhanced features</span>
            </li>
            <li class="flex items-center">
                            <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />

              <span class="text-gray-700">Never expires</span>
            </li>
            <li class="flex items-center">
                            <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />

              <span class="text-gray-700">Costs less over time</span>
            </li>
            <li class="flex items-center">
                            <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />

              <span class="text-gray-700">Volume discount</span>
            </li>
          </ul>

          <!-- CTA Button -->
          <a 
            href="https://www.lxware.hk/products/1panel-professional-edition" 
            target="_blank"
            class="w-full inline-flex justify-center items-center px-6 py-3 bg-1panel-gradient text-white rounded-lg font-medium transition-all duration-300 hover:shadow-lg hover:scale-105"
          >
            Buy now
          </a>
        </div>
      </div>

      <!-- Pro Edition - Subscription -->
      <div class="fade-in-up card group hover:scale-105 transition-transform duration-300" style="animation-delay: 0.5s;">
        <div class="text-center p-4">
          <!-- Plan Header -->
          <div class="mb-6">
            <div class="flex items-center justify-center space-x-2 font-medium text-gray-500 mb-2">
              <Icon name="mdi:diamond-stone" class="w-5 h-5 text-yellow-500 flex-shrink-0" />
              <span>Pro Edition</span>
            </div>
            <h3 class="text-2xl font-bold text-gray-800 mb-4">Subscription</h3>
            
              <!-- Price Display -->
              <div class="mb-2">
                <div class="flex items-baseline justify-center">
                  <span id="subscription-price" class="text-5xl font-bold text-gray-800">$80</span>
                  <span id="subscription-period" class="text-gray-600 text-sm ml-2">/ per year</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Features -->
          <ul class="space-y-4 mb-8 text-left">
            <li class="flex items-center">
              <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
              <span class="text-gray-700">All features of OSS Edition</span>
            </li>
            <li class="flex items-center">
              <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
              <span class="text-gray-700">Enhanced features</span>
            </li>
            <li class="flex items-center">
              <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
              <span class="text-gray-700">Start at a low cost</span>
            </li>
            <li class="flex items-center">
              <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
              <span class="text-gray-700">Flexibility on payment</span>
            </li>
            <li class="flex items-center">
              <Icon name="mdi:check" class="w-5 h-5 text-green-500 mr-3 flex-shrink-0" />
              <span class="text-gray-700">Enjoy the latest updates</span>
            </li>
          </ul>

          <!-- CTA Button -->
          <a 
            id="subscription-button"
            href="https://www.lxware.hk/products/1panel-pro-edition-subscription-license" 
            target="_blank"
            class="w-full inline-flex justify-center items-center px-6 py-3 bg-gray-100 border border-gray-300 text-gray-700 rounded-lg font-medium transition-all duration-300 hover:bg-gray-200 hover:border-gray-400"
          >
            Buy now
          </a>
        </div>
      </div>
    </div>

    <!-- Feature Comparison Table -->
    <div class="mt-20">
      <div class="text-center mb-12">
        <h3 class="fade-in-up text-3xl font-bold text-gray-800 mb-4">OSS Edition VS. Pro Edition</h3>
        <p class="fade-in-up text-lg text-gray-600">Compare features to find the perfect plan for your needs</p>
      </div>
      
      <div class="fade-in-up overflow-x-auto" style="animation-delay: 0.6s;">
        <table class="w-full max-w-4xl mx-auto bg-white rounded-xl shadow-lg border-2 border-gray-200 overflow-hidden feature-table">
          <thead>
            <tr class="border-b border-gray-200 bg-gradient-to-r from-gray-50 to-gray-100">
              <th class="text-left p-6 font-semibold text-gray-800">Features</th>
              <th class="text-center p-6 font-semibold text-gray-800">
                <span class="inline-flex items-center">
                  <Icon name="carbon:logo-github" class="w-5 h-5 mr-2 flex-shrink-0" />OSS Edition
                </span>
              </th>
              <th class="text-center p-6 font-semibold text-1panel">
                <span class="inline-flex items-center">
                  <Icon name="mdi:diamond-stone" class="w-5 h-5 text-yellow-500  mr-2 flex-shrink-0" />Pro Edition
                </span>
              </th>
            </tr>
          </thead>
          <tbody>
            <!-- AI Features -->
            <tr class="bg-gradient-to-r from-blue-50 to-blue-100 border-b border-blue-200 category-row">
              <td class="p-6 font-semibold text-blue-800" colspan="3">
                <span class="inline-flex items-center gap-2">
                  <Icon name="mdi:robot-outline" class="w-5 h-5 flex-shrink-0" />
                  AI Model Management
                </span>
              </td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">OpenClaw Agents Management</td>
              <!-- OSS Edition -->
              <td class="p-6 text-center">
                <div class="flex justify-center">
                  <span class="flex items-start gap-2 text-gray-700">
                    <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Up to 5
                  </span>
                </div>
              </td>
              <!-- Pro Edition -->
              <td class="p-6 text-center">
                <div class="flex justify-center">
                  <span class="flex items-start gap-2 text-gray-700">
                    <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Unlimited
                  </span>
                </div>
              </td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-blue-50 transition duration-200">
              <td class="p-6 text-gray-700 font-medium">AI Model Management</td>
              <!-- OSS Edition -->
              <td class="p-6 text-center">
                <div class="flex justify-center">
                  <div class="flex flex-col gap-2 items-start">
                    <span class="flex items-start gap-2 text-gray-700">
                      <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                      Ollama
                    </span>
                    <span class="flex items-center gap-2 text-gray-700">
                      <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                      TensorRT-LLM
                    </span>
                    <span class="flex items-center gap-2 text-gray-700">
                      <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                      </svg>
                      vLLM
                    </span>
                  </div>
                </div>
              </td>
              <!-- Pro Edition -->
              <td class="p-6 text-center">
                <div class="flex justify-center">
                <div class="flex flex-col gap-2 items-start">
                  <span class="flex items-center gap-2 text-gray-700">
                    <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Ollama
                  </span>
                  <span class="flex items-center gap-2 text-gray-700">
                    <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    TensorRT-LLM
                  </span>
                  <span class="flex items-center gap-2 text-gray-700">
                    <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    vLLM
                  </div>
                </div>
              </td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">MCP Servers Management</td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">GPU Monitoring</td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
            </tr>

            <!-- Website Management -->
            <tr class="bg-gradient-to-r from-cyan-50 to-cyan-100 border-b border-cyan-200 category-row">
              <td class="p-6 font-semibold text-cyan-800" colspan="3">
                <span class="inline-flex items-center">
                  <Icon name="mdi:web" class="w-5 h-5 mr-2 flex-shrink-0" />
                  Website Management
                </span>
              </td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">Website Management (Unlimited)</td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">Website Backup</td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">Certificate Management</td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">Website Monitoring Reports</td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-red-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
            </tr>

            <!-- Multi-node Management -->
            <tr class="bg-gradient-to-r from-violet-50 to-violet-100 border-b border-violet-200 category-row">
              <td class="p-6 font-semibold text-violet-800" colspan="3">
                <span class="inline-flex items-center">
                  <Icon name="mdi:server-network" class="w-5 h-5 mr-2 flex-shrink-0" />
                  Multi-node Management
                </span>
              </td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">Multi-node Switch</td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-red-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">Cross-node File Transfer</td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-red-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
            </tr>

            <!-- Daily Ops -->
            <tr class="bg-gradient-to-r from-indigo-50 to-indigo-100 border-b border-indigo-200 category-row">
              <td class="p-6 font-semibold text-indigo-800" colspan="3">
                <span class="inline-flex items-center">
                  <Icon name="carbon:tool-box" class="w-5 h-5 mr-2 flex-shrink-0" />
                  Daily Ops
                </span>
              </td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">FTP / Container Management</td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">File Management</td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">Server Monitoring</td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
            </tr>
            <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
              <td class="p-6 text-gray-700 font-medium">Server Terminal</td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
              <td class="p-6 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></td>
            </tr>
