---
const partners = [
  { name: "英特尔", logoSrc: "/images/partners/intel.svg" },
  { name: "戴尔", logoSrc: "/images/partners/dell.svg" },
  { name: "超聚变", logoSrc: "/images/partners/xfusion.svg" },
  { name: "联想", logoSrc: "/images/partners/lenovo.png" },
  { name: "华鲲振宇", logoSrc: "/images/partners/huakun.png" },
  { name: "博客园", logoSrc: "/images/partners/cnblogs.svg" },
];
const contactEmail = "support@fit2cloud.com";
---

<section id="partners" class="section-padding bg-gray-50">
  <div class="container-custom">
    <div class="text-center mb-16">
      <h2 class="fade-in-up text-4xl lg:text-5xl font-bold text-gray-800 mb-6">
        可靠的
        <span class="text-1panel-gradient">合作伙伴</span>
      </h2>
      <p
        class="fade-in-up text-xl text-gray-600 max-w-3xl mx-auto"
        style="animation-delay: 0.2s;"
      >
        与优秀生态伙伴携手，为用户提供更完善的产品与服务。
      </p>
    </div>

    <div
      class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 lg:gap-6"
      aria-label="合作伙伴列表"
    >
      {
        partners.map((partner) => (
          <div class="fade-in-up" style="animation-delay: 0.1s;">
            <div class="group bg-white border border-gray-200 rounded-xl px-4 py-5 text-center shadow-sm hover:shadow-md hover:border-gray-300 transition-all duration-300">
              <div class="h-10 flex items-center justify-center">
                <img
                  src={partner.logoSrc}
                  alt={`${partner.name} Logo`}
                  class="h-8 w-auto max-w-full object-contain opacity-90 group-hover:opacity-100 transition-opacity duration-300"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="text-center mt-10">
      <div
        class="inline-flex items-center px-6 py-3 bg-white border border-gray-300 text-gray-700 rounded-lg font-medium transition-all duration-300 hover:border-gray-400 hover:bg-gray-50 shadow-sm hover:shadow-md"
        aria-label="合作联系邮箱"
      >
        <span>合作联系：</span>
        <a
          href={`mailto:${contactEmail}`}
          class="ml-2 text-1panel hover:underline underline-offset-4"
        >
          {contactEmail}
        </a>
      </div>
    </div>
  </div>
</section>
