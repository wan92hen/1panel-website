---
// Fit2cloudHeader component for 1Panel website

const openSourceProducts = [
  {
    name: "1Panel",
    description: "现代化、开源的 Linux 面板",
    href: "https://1panel.cn",
  },
  {
    name: "Cordys",
    description: "新一代的开源 AI CRM 系统",
    href: "https://cordys.cn",
  },
  {
    name: "JumpServer",
    description: "广受欢迎的开源堡垒机",
    href: "https://www.jumpserver.org",
  },
  {
    name: "MaxKB",
    description: "强大易用的企业级智能体平台",
    href: "https://maxkb.cn",
  },
  {
    name: "DataEase",
    description: "人人可用的开源 BI 工具",
    href: "https://dataease.cn",
  },
  {
    name: "SQLBot",
    description: "基于大模型的智能问数系统",
    href: "https://sqlbot.org",
  },
  {
    name: "MeterSphere",
    description: "新一代的开源持续测试工具",
    href: "https://metersphere.io",
  },
  {
    name: "Halo",
    description: "强大易用的开源建站工具",
    href: "https://halo.run",
  },
];
---

<div class="hidden bg-black text-white text-sm py-2 px-4 relative z-[9999] lg:block">
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const dropdownContainer = document.getElementById("f2c-dropdown-container");
      const dropdownTrigger = document.getElementById("f2c-dropdown-trigger");
      const dropdownBtn = document.getElementById("f2c-dropdown-btn");
      const dropdown = document.getElementById("f2c-dropdown");

      if (dropdownContainer && dropdownTrigger && dropdownBtn && dropdown) {
        const setDropdownOpen = (isOpen) => {
          dropdown.classList.toggle("hidden", !isOpen);
          dropdownBtn.classList.toggle("rotate-180", isOpen);
          dropdownTrigger.setAttribute("aria-expanded", String(isOpen));
        };

        dropdownTrigger.addEventListener("click", () => {
          setDropdownOpen(dropdown.classList.contains("hidden"));
        });

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (
            target instanceof Node &&
            !dropdownContainer.contains(target) &&
            !dropdown.classList.contains("hidden")
          ) {
            setDropdownOpen(false);
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && !dropdown.classList.contains("hidden")) {
            setDropdownOpen(false);
          }
        });

        dropdown.addEventListener("click", (event) => {
          const target = event.target;
          if (target instanceof Element && target.closest("a")) {
            setDropdownOpen(false);
          }
        });
      }
    });
  </script>
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <div class="flex items-center">
      <a
        href="https://www.fit2cloud.com/"
        class="text-white hover:text-gray-200 transition-colors duration-200 font-medium"
        ><img
          src="images/logo-light-FIT2CLOUD.svg"
          alt="FIT2CLOUD"
          class="h-5 w-auto"
        /></a
      >
    </div><div class="relative" id="f2c-dropdown-container">
      <button
        id="f2c-dropdown-trigger"
        class="flex items-center text-white hover:text-gray-200 transition-colors duration-200 px-3 py-1 rounded"
        aria-expanded="false"
        aria-controls="f2c-dropdown"
        ><span>了解飞致云旗下开源产品</span><svg
          id="f2c-dropdown-btn"
          class="ml-2 w-4 h-4 transition-transform duration-200"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 9l-7 7-7-7"></path></svg
        ></button
      >
      <div
        class="absolute right-0 top-full mt-1 w-80 bg-white border border-gray-200 rounded-lg shadow-xl py-2 z-[9999] hidden"
        id="f2c-dropdown"
      >
        {
          openSourceProducts.map((product) => (
            <a
              href={product.href}
              target="_blank"
              rel="noopener noreferrer"
              class="block px-4 py-3 text-gray-800 hover:bg-gray-300 transition-colors duration-200 border-b border-gray-100 last:border-b-0"
            >
              <div class="flex flex-col">
                <span class="font-semibold text-blue-600 mb-1">
                  {product.name}
                </span>
                <span class="text-sm text-gray-600">
                  {product.description}
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>
