---
// Footer component for 1Panel website
import { Icon } from 'astro-icon/components'
import { t, getTranslations } from '../i18n/utils';
import type { TranslationDict } from '../i18n/utils';

interface Props {
  lang?: string;
  basePath?: string;
  translations?: TranslationDict;
}

const { translations: rawTranslations } = Astro.props;
const translations = rawTranslations && Object.keys(rawTranslations || {}).length > 0 ? rawTranslations! : getTranslations('en');
---

<footer class="bg-dark-900 border-t border-gray-800 py-12">
  <div class="container-custom">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 mb-8">
      <!-- Company Info -->
      <div class="col-span-1 lg:col-span-2">
        <div class="flex items-center space-x-3 mb-4">
          <span class="text-xl font-bold text-white">{t(translations, 'footer.companyName')}</span>
        </div>
        <p class="text-gray-400 mb-6 max-w-md">
          {t(translations, 'footer.companyDesc')}
        </p>
        <!-- 社区图标 -->
        <ul class="flex space-x-4 mt-2">
          <li>
            <a href="https://github.com/1Panel-dev/1Panel" target="_blank" class="text-gray-400 hover:text-white transition-colors duration-300 inline-flex items-center" aria-label="GitHub">
              <Icon name="carbon:logo-github" class="w-5 h-5" />
            </a>
          </li>
          <li>
            <a href="https://github.com/1Panel-dev/1Panel/discussions" target="_blank" class="text-gray-400 hover:text-white transition-colors duration-300 inline-flex items-center" aria-label="Community Forum">
              <Icon name="carbon:forum" class="w-5 h-5" />
            </a>
          </li>
          <li>
            <a href="https://x.com/lxware_x" target="_blank" class="text-gray-400 hover:text-white transition-colors duration-300 inline-flex items-center" aria-label="X">
              <Icon name="carbon:logo-x" class="w-5 h-5" />
            </a>
          </li>
          <li>
            <a href="https://www.youtube.com/@1Panel-linux" target="_blank" class="text-gray-400 hover:text-white transition-colors duration-300 inline-flex items-center" aria-label="YouTube">
              <Icon name="carbon:logo-youtube" class="w-5 h-5" />
            </a>
          </li>
          <li>
            <a href="https://discord.gg/bUpUqWqdRr" target="_blank" class="text-gray-400 hover:text-white transition-colors duration-300 inline-flex items-center" aria-label="Discord">
              <Icon name="carbon:logo-discord" class="w-5 h-5" />
            </a>
          </li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-4">{t(translations, 'footer.resources')}</h4>
        <ul class="space-y-3">
          <li><a href="/blog.html" target="_blank" class="text-gray-400 hover:text-white transition-colors duration-300 inline-flex items-center"><Icon name="carbon:blog" class="w-4 h-4 mr-2" />{t(translations, 'footer.blog')}</a></li>
          <li><a href="https://1panel.pro/docs/" target="_blank" class="text-gray-400 hover:text-white transition-colors duration-300 inline-flex items-center"><Icon name="carbon:documentation" class="w-4 h-4 mr-2" />{t(translations, 'footer.documentation')}</a></li>
      </div>
      <!-- Compare -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-4">{t(translations, 'footer.compare')}</h4>
        <ul class="space-y-3">
          <li><a href="/1panel-vs-cpanel.html" class="text-gray-400 hover:text-white transition-colors duration-300"> VS cPanel</a></li>
          <li><a href="/1panel-vs-webmin.html" class="text-gray-400 hover:text-white transition-colors duration-300"> VS Webmin</a></li>
          <li><a href="/1panel-vs-plesk.html" class="text-gray-400 hover:text-white transition-colors duration-300"> VS Plesk</a></li>
        </ul>
      </div>
      <!-- Quick Links -->
      <div>
        <h4 class="text-lg font-semibold text-white mb-4">{t(translations, 'footer.links')}</h4>
        <ul class="space-y-3">
          <li><a href="https://jumpserver.com" class="text-gray-400 hover:text-white transition-colors duration-300">{t(translations, 'footer.jumpserver')}</a></li>
          <li><a href="https://lxware.hk/pages/about" class="text-gray-400 hover:text-white transition-colors duration-300">{t(translations, 'footer.aboutLxware')}</a></li>
          <li><a href="mailto:hi@lxware.hk" class="text-gray-400 hover:text-white transition-colors duration-300">{t(translations, 'footer.contactUs')}</a></li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-gray-800 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <div class="text-gray-400 text-sm mb-4 md:mb-0">
          © <span id="footer-year"></span> LXware. {t(translations, 'footer.copyright')}
        </div>
        <script is:inline>
          document.addEventListener('DOMContentLoaded', function() {
            const yearSpan = document.getElementById('footer-year');
            if (yearSpan) {
              yearSpan.textContent = new Date().getFullYear();
            }
          });
        </script>
        <div class="flex space-x-6 text-sm">
          <a href="https://www.lxware.hk/policies/terms-of-service" target="_blank" class="text-gray-400 hover:text-white transition-colors duration-300">{t(translations, 'footer.termsOfService')}</a>
          <a href="https://www.lxware.hk/policies/privacy-policy" target="_blank" class="text-gray-400 hover:text-white transition-colors duration-300">{t(translations, 'footer.privacyPolicy')}</a>
      </div>
    </div>

    <div id="side-bar" class="fixed bottom-8 right-8 z-20 flex flex-col items-end space-y-4 md:space-y-6">
      <!-- 联系我们按钮 -->
      <a 
        href="mailto:hi@lxware.hk" 
        class="contact-us-button flex items-center gap-2 px-5 py-3 bg-gradient-to-br from-blue-600 via-blue-500 to-purple-600 text-white font-semibold rounded-full shadow-xl border-2 border-white/10 hover:shadow-2xl hover:scale-110 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-blue-500/40 backdrop-blur"
        style="backdrop-filter: blur(6px);"
        aria-label="Contact Us"
      >
        <Icon name="carbon:email" class="w-5 h-5 text-blue-200" />
        <span class="hidden sm:inline">{t(translations, 'footer.contactUs')}</span>
      </a>

      <!-- 回到顶部按钮 -->
      <button 
        id="back-to-top" 
        class="flex items-center justify-center px-5 py-3 bg-gradient-to-br from-blue-600 via-blue-500 to-purple-600 text-white font-semibold rounded-full shadow-xl border-2 border-white/10 hover:shadow-2xl hover:scale-110 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-blue-500/40 backdrop-blur opacity-0 invisible z-50"
        style="backdrop-filter: blur(6px);"
        aria-label="Back to top"
      >
        <Icon name="carbon:arrow-up" class="w-5 h-5 text-blue-200" />
      </button>
    </div>
  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Back to top button functionality
    const backToTopBtn = document.getElementById('back-to-top');
    
    if (backToTopBtn) {
      // Show/hide button based on scroll position
      window.addEventListener('scroll', () => {
        if (window.pageYOffset > 300) {
          backToTopBtn.classList.remove('opacity-0', 'invisible');
          backToTopBtn.classList.add('opacity-100', 'visible');
        } else {
          backToTopBtn.classList.add('opacity-0', 'invisible');
          backToTopBtn.classList.remove('opacity-100', 'visible');
        }
      });

      // Smooth scroll to top
      backToTopBtn.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    }
  });
</script>
