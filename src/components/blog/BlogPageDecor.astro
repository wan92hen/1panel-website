---
/**
 * Subtle background orbs aligned with Hero / site marketing sections.
 */
---

<div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
  <div
    class="absolute top-12 right-[8%] w-44 h-44 rounded-full blur-3xl bg-1panel opacity-[0.12] animate-float"
  />
  <div
    class="absolute top-1/3 left-[4%] w-32 h-32 rounded-full blur-2xl bg-1panel opacity-[0.1] animate-float"
    style="animation-delay: -2s;"
  />
  <div
    class="absolute bottom-24 right-[15%] w-56 h-56 rounded-full blur-3xl bg-1panel opacity-[0.08] animate-float"
    style="animation-delay: -4s;"
  />
</div>
