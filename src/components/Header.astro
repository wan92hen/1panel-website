---
// Header component for 1Panel website
import { Icon } from "astro-icon/components";
import Fit2cloudHeader from "./Fit2cloudHeader.astro";
---

<Fit2cloudHeader />
<header
  class="sticky top-0 left-0 right-0 z-50 bg-dark-200/90 backdrop-blur-md border-b border-gray-200"
>
  <nav class="container-custom">
    <div class="flex items-center justify-between h-16 lg:h-18">
      <!-- Logo -->
      <div class="flex items-center space-x-3">
        <a href="/">
          <img src="/images/logo-blue.png" alt="1Panel Logo" class="h-12" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center space-x-8">
        <a
          href="/versions.html"
          class="relative inline-flex items-center text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 group"
        >
          <span class="nav-link-label" data-text="版本对比">版本对比</span>
        </a>
        <div id="enterprise-dropdown-container" class="relative">
          <button
            id="enterprise-dropdown-trigger"
            type="button"
            class="relative inline-flex items-center text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 group"
            aria-expanded="false"
            aria-controls="enterprise-dropdown"
          >
            <span class="nav-link-label" data-text="企业版">
              <span class="nav-link-content">
                <span>企业版</span>
                <Icon
                  id="enterprise-dropdown-icon"
                  name="carbon:chevron-down"
                  class="w-4 h-4 transition-transform duration-200"
                />
              </span>
            </span>
          </button>
          <div
            id="enterprise-dropdown"
            class="absolute left-1/2 top-full z-[9999] hidden w-48 -translate-x-1/2 pt-5"
          >
            <div class="rounded-lg border border-gray-100 bg-white py-2 shadow-xl shadow-gray-900/10">
              <a
                href="/enterprise.html"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                概览
              </a>
              <a
                href="/ai-gateway.html"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                AI 网关
              </a>
              <a
                href="/skills-hub.html"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                Skills Hub
              </a>
              <a
                href="/user-management.html"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                用户管理
              </a>
              <a
                href="/security-ops-report.html"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                安全运维报表
              </a>
            </div>
          </div>
        </div>
        <div id="ai-appliance-dropdown-container" class="relative">
          <button
            id="ai-appliance-dropdown-trigger"
            type="button"
            class="relative inline-flex items-center text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 group"
            aria-expanded="false"
            aria-controls="ai-appliance-dropdown"
          >
            <span class="nav-link-label" data-text="AI 一体机">
              <span class="nav-link-content">
                <span>AI 一体机</span>
                <Icon
                  id="ai-appliance-dropdown-icon"
                  name="carbon:chevron-down"
                  class="w-4 h-4 transition-transform duration-200"
                />
              </span>
            </span>
          </button>
          <div
            id="ai-appliance-dropdown"
            class="absolute left-1/2 top-full z-[9999] hidden w-64 -translate-x-1/2 pt-5"
          >
            <div class="rounded-lg border border-gray-100 bg-white py-2 shadow-xl shadow-gray-900/10">
              <a
                href="/openclaw.html"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                AI 助理一体机（GB10版）
              </a>
              <a
                href="/aicoding_b70.html"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                AI 编程一体机（B70版）
              </a>
            </div>
          </div>
        </div>
        <a
          href="https://apps.fit2cloud.com/1panel"
          target="_blank"
          class="inline-flex items-center text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
          ><span class="nav-link-label" data-text="应用商店">应用商店</span></a
        >
        <div id="support-dropdown-container" class="relative">
          <button
            id="support-dropdown-trigger"
            type="button"
            class="relative inline-flex items-center text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 group"
            aria-expanded="false"
            aria-controls="support-dropdown"
          >
            <span class="nav-link-label" data-text="帮助与支持">
              <span class="nav-link-content">
                <span>帮助与支持</span>
                <Icon
                  id="support-dropdown-icon"
                  name="carbon:chevron-down"
                  class="w-4 h-4 transition-transform duration-200"
                />
              </span>
            </span>
          </button>
          <div
            id="support-dropdown"
            class="absolute left-1/2 top-full z-[9999] hidden w-44 -translate-x-1/2 pt-5"
          >
            <div class="rounded-lg border border-gray-100 bg-white py-2 shadow-xl shadow-gray-900/10">
              <a
                href="https://1panel.cn/docs"
                target="_blank"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                使用手册
              </a>
              <a
                href="https://bbs.fit2cloud.com/c/1p/"
                target="_blank"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                论坛求助
              </a>
              <a
                href="/blog.html"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                产品动态
              </a>
            </div>
          </div>
        </div>
        <a
          href="https://demo.1panel.cn/"
          target="_blank"
          class="inline-flex items-center text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
          ><span class="nav-link-label" data-text="在线体验">在线体验</span></a
        >
        <div class="flex items-center space-x-4">
          <a
            href="https://jsj.top/f/umuYtv"
            target="_blank"
            class="btn-secondary text-sm inline-flex items-center"
          >
            <Icon name="carbon:demo" class="w-5 h-5 mr-2" />
            企业版试用
          </a>
          <a
            href="https://github.com/1Panel-dev/1Panel"
            target="_blank"
            class="btn-primary text-sm inline-flex items-center"
          >
            <Icon name="carbon:logo-github" class="w-5 h-5 mr-2" />
            代码仓库
          </a>
        </div>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-gray-700 hover:text-gray-900"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="lg:hidden hidden pb-4">
      <div class="flex flex-col space-y-4">
        <a
          href="/versions.html"
          class="relative text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 group"
        >
          版本对比
        </a>
        <div class="space-y-3">
          <div class="text-sm font-semibold text-gray-900">企业版</div>
          <div class="flex flex-col space-y-3 pl-3 border-l border-gray-200">
            <a
              href="/enterprise.html"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              概览
            </a>
            <a
              href="/ai-gateway.html"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              AI 网关
            </a>
            <a
              href="/skills-hub.html"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              Skills Hub
            </a>
            <a
              href="/user-management.html"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              用户管理
            </a>
            <a
              href="/security-ops-report.html"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              安全运维报表
            </a>
          </div>
        </div>
        <div class="space-y-3">
          <div class="text-sm font-semibold text-gray-900">AI 一体机</div>
          <div class="flex flex-col space-y-3 pl-3 border-l border-gray-200">
            <a
              href="/openclaw.html"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              AI 助理一体机（GB10版）
            </a>
            <a
              href="/aicoding_b70.html"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              AI 编程一体机（B70版）
            </a>
          </div>
        </div>
        <a
          href="#appstore"
          target="_blank"
          class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
          >应用商店</a
        >
        <div class="space-y-3">
          <div class="text-sm font-semibold text-gray-900">帮助与支持</div>
          <div class="flex flex-col space-y-3 pl-3 border-l border-gray-200">
            <a
              href="https://1panel.cn/docs"
              target="_blank"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              使用手册
            </a>
            <a
              href="https://bbs.fit2cloud.com/c/1p/"
              target="_blank"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              论坛求助
            </a>
            <a
              href="/blog.html"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              产品动态
            </a>
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  .nav-link-label {
    display: inline-grid;
    align-items: center;
  }

  .nav-link-content,
  .nav-link-label::after {
    grid-area: 1 / 1;
  }

  .nav-link-content {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link-label::after {
    content: attr(data-text);
    font-weight: 700;
    white-space: pre;
    visibility: hidden;
    height: 0;
    overflow: hidden;
    pointer-events: none;
    user-select: none;
  }

  .nav-link-flame {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }
</style>

<script>
  // Mobile menu toggle
  document.addEventListener("DOMContentLoaded", () => {
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const enterpriseDropdownContainer = document.getElementById(
      "enterprise-dropdown-container"
    );
    const enterpriseDropdownTrigger = document.getElementById(
      "enterprise-dropdown-trigger"
    );
    const enterpriseDropdown = document.getElementById("enterprise-dropdown");
    const enterpriseDropdownIcon = document.getElementById(
      "enterprise-dropdown-icon"
    );
    const aiDropdownContainer = document.getElementById(
      "ai-appliance-dropdown-container"
    );
    const aiDropdownTrigger = document.getElementById(
      "ai-appliance-dropdown-trigger"
    );
    const aiDropdown = document.getElementById("ai-appliance-dropdown");
    const aiDropdownIcon = document.getElementById(
      "ai-appliance-dropdown-icon"
    );
    const supportDropdownContainer = document.getElementById(
      "support-dropdown-container"
    );
    const supportDropdownTrigger = document.getElementById(
      "support-dropdown-trigger"
    );
    const supportDropdown = document.getElementById("support-dropdown");
    const supportDropdownIcon = document.getElementById(
      "support-dropdown-icon"
    );

    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
      });

      // Close mobile menu when clicking on a link
      const mobileLinks = mobileMenu.querySelectorAll("a");
      mobileLinks.forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu.classList.add("hidden");
        });
      });
    }

    const setupDropdown = (container, trigger, dropdown, icon) => {
      if (!container || !trigger || !dropdown) {
        return;
      }

      const setDropdownOpen = (isOpen) => {
        dropdown.classList.toggle("hidden", !isOpen);
        trigger.setAttribute("aria-expanded", String(isOpen));
        icon?.classList.toggle("rotate-180", isOpen);
      };

      trigger.addEventListener("click", (event) => {
        event.stopPropagation();
        setDropdownOpen(dropdown.classList.contains("hidden"));
      });

      container.addEventListener("mouseenter", () => {
        setDropdownOpen(true);
      });

      container.addEventListener("mouseleave", () => {
        setDropdownOpen(false);
      });

      document.addEventListener("click", (event) => {
        if (
          event.target instanceof Node &&
          !container.contains(event.target)
        ) {
          setDropdownOpen(false);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setDropdownOpen(false);
        }
      });
    };

    setupDropdown(
      enterpriseDropdownContainer,
      enterpriseDropdownTrigger,
      enterpriseDropdown,
      enterpriseDropdownIcon
    );
    setupDropdown(
      aiDropdownContainer,
      aiDropdownTrigger,
      aiDropdown,
      aiDropdownIcon
    );
    setupDropdown(
      supportDropdownContainer,
      supportDropdownTrigger,
      supportDropdown,
      supportDropdownIcon
    );
  });
</script>
