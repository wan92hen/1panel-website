---
// Header component for 1Panel website
import { Icon } from "astro-icon/components";
import Fit2cloudHeader from "./Fit2cloudHeader.astro";
---

<Fit2cloudHeader />
<header
  class="sticky top-0 left-0 right-0 z-50 bg-dark-200/90 backdrop-blur-md border-b border-gray-200"
>
  <nav class="container-custom">
    <div class="flex items-center justify-between h-16 lg:h-18">
      <!-- Logo -->
      <div class="flex items-center space-x-3">
        <a href="https://1panel.cn" target="_blank">
          <img src="./images/logo-blue.png" alt="1Panel Logo" class="h-12" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center space-x-8">
        <div id="ai-appliance-dropdown-container" class="relative">
          <button
            id="ai-appliance-dropdown-trigger"
            type="button"
            class="relative inline-flex items-center text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 group"
            aria-expanded="false"
            aria-controls="ai-appliance-dropdown"
          >
            <span class="nav-link-label" data-text="AI 一体机">
              <span class="nav-link-content">
                <span>AI 一体机</span>
                <Icon
                  id="ai-appliance-dropdown-icon"
                  name="carbon:chevron-down"
                  class="w-4 h-4 transition-transform duration-200"
                />
              </span>
            </span>
          </button>
          <div
            id="ai-appliance-dropdown"
            class="absolute left-1/2 top-full z-[9999] hidden w-64 -translate-x-1/2 pt-5"
          >
            <div class="rounded-lg border border-gray-100 bg-white py-2 shadow-xl shadow-gray-900/10">
              <a
                href="/openclaw.html"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                OpenClaw 一体机（GB10版）
              </a>
              <a
                href="/aicoding_b70.html"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                AI Coding 一体机（B70版）
              </a>
              <a
                href="/aicoding_gb10.html"
                class="block px-4 py-3 text-sm text-gray-700 transition-colors duration-200 hover:bg-blue-50 hover:text-1panel"
              >
                AI Coding 一体机（GB10版）
              </a>
            </div>
          </div>
        </div>
        <a
          href="/versions.html"
          class="relative inline-flex items-center text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 group"
        >
          <span class="nav-link-label" data-text="版本对比">版本对比</span>
        </a>
        <a
          href="https://apps.fit2cloud.com/1panel"
          target="_blank"
          class="inline-flex items-center text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
          ><span class="nav-link-label" data-text="应用商店">应用商店</span></a
        >
        <a
          href="https://bbs.fit2cloud.com/c/1p/"
          target="_blank"
          class="inline-flex items-center text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
          ><span class="nav-link-label" data-text="论坛求助">论坛求助</span></a
        >
        <a
          href="https://1panel.cn/docs"
          target="_blank"
          class="inline-flex items-center text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
          ><span class="nav-link-label" data-text="使用手册">使用手册</span></a
        >
        <a
          href="https://1panel.pro/"
          target="_blank"
          class="inline-flex items-center text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
          ><span class="nav-link-label" data-text="English">English</span></a
        >
        <div class="flex items-center space-x-4">
          <a
            href="https://demo.1panel.cn/"
            target="_blank"
            class="btn-secondary text-sm inline-flex items-center"
          >
            <Icon name="carbon:demo" class="w-5 h-5 mr-2" />
            在线体验
          </a>
          <a
            href="https://github.com/1Panel-dev/1Panel"
            target="_blank"
            class="btn-primary text-sm inline-flex items-center"
          >
            <Icon name="carbon:logo-github" class="w-5 h-5 mr-2" />
            代码仓库
          </a>
        </div>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-gray-700 hover:text-gray-900"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="lg:hidden hidden pb-4">
      <div class="flex flex-col space-y-4">
        <div class="space-y-3">
          <div class="text-sm font-semibold text-gray-900">AI 一体机</div>
          <div class="flex flex-col space-y-3 pl-3 border-l border-gray-200">
            <a
              href="/openclaw.html"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              OpenClaw 一体机（GB10版）
            </a>
            <a
              href="/aicoding_b70.html"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              AI Coding 一体机（B70版）
            </a>
            <a
              href="/aicoding_gb10.html"
              class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
            >
              AI Coding 一体机（GB10版）
            </a>
          </div>
        </div>
        <a
          href="/versions.html"
          class="relative text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 group"
        >
          版本对比
        </a>
        <a
          href="https://1panel.cn/docs/v2/installation/package_installation/"
          target="_blank"
          class="relative text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 group"
        >
          离线版
        </a>
        <a
          href="#appstore"
          target="_blank"
          class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
          >应用商店</a
        >
        <a
          href="https://bbs.fit2cloud.com/c/1p/"
          target="_blank"
          class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
          >论坛求助</a
        >
        <a
          href="https://1panel.cn/docs"
          target="_blank"
          class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300"
          >使用手册</a
        >
        <div class="flex flex-col space-y-3 pt-4">
          <a
            href="https://demo.1panel.cn/"
            target="_blank"
            class="btn-secondary text-sm text-center inline-flex items-center justify-center"
          >
            <Icon name="carbon:demo" class="w-5 h-5 mr-3 text-gray-700" />
            在线体验
          </a>
          <a
            href="https://github.com/1Panel-dev/1Panel"
            target="_blank"
            class="btn-primary text-sm text-center"
          >
            代码仓库
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  .nav-link-label {
    display: inline-grid;
    align-items: center;
  }

  .nav-link-content,
  .nav-link-label::after {
    grid-area: 1 / 1;
  }

  .nav-link-content {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link-label::after {
    content: attr(data-text);
    font-weight: 700;
    white-space: pre;
    visibility: hidden;
    height: 0;
    overflow: hidden;
    pointer-events: none;
    user-select: none;
  }

  .nav-link-flame {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }
</style>

<script>
  // Mobile menu toggle
  document.addEventListener("DOMContentLoaded", () => {
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const aiDropdownContainer = document.getElementById(
      "ai-appliance-dropdown-container"
    );
    const aiDropdownTrigger = document.getElementById(
      "ai-appliance-dropdown-trigger"
    );
    const aiDropdown = document.getElementById("ai-appliance-dropdown");
    const aiDropdownIcon = document.getElementById(
      "ai-appliance-dropdown-icon"
    );

    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
      });

      // Close mobile menu when clicking on a link
      const mobileLinks = mobileMenu.querySelectorAll("a");
      mobileLinks.forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu.classList.add("hidden");
        });
      });
    }

    if (aiDropdownContainer && aiDropdownTrigger && aiDropdown) {
      const setAIDropdownOpen = (isOpen) => {
        aiDropdown.classList.toggle("hidden", !isOpen);
        aiDropdownTrigger.setAttribute("aria-expanded", String(isOpen));
        aiDropdownIcon?.classList.toggle("rotate-180", isOpen);
      };

      aiDropdownTrigger.addEventListener("click", (event) => {
        event.stopPropagation();
        setAIDropdownOpen(aiDropdown.classList.contains("hidden"));
      });

      aiDropdownContainer.addEventListener("mouseenter", () => {
        setAIDropdownOpen(true);
      });

      aiDropdownContainer.addEventListener("mouseleave", () => {
        setAIDropdownOpen(false);
      });

      document.addEventListener("click", (event) => {
        if (
          event.target instanceof Node &&
          !aiDropdownContainer.contains(event.target)
        ) {
          setAIDropdownOpen(false);
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setAIDropdownOpen(false);
        }
      });
    }
  });
</script>
