---
// Header component for 1Panel website
import { Icon } from 'astro-icon/components'
import { DEFAULT_LOCALE, SUPPORTED_LOCALES, getLocaleLabel } from '../i18n/config';
import { t, getTranslations } from '../i18n/utils';
import type { TranslationDict } from '../i18n/utils';
import { publicAsset } from '../lib/asset';

interface Props {
  lang?: string;
  basePath?: string;
  translations?: TranslationDict;
}

const { lang, basePath = './', translations: rawTranslations } = Astro.props;
const logoSrc = publicAsset('images/logo-blue.png');
const translations = rawTranslations && Object.keys(rawTranslations).length > 0 ? rawTranslations : getTranslations('en');
const currentLocale = lang ?? DEFAULT_LOCALE;
const prefix = !lang || lang === DEFAULT_LOCALE ? '' : `/${lang}`;
const supportedLocaleCodes = SUPPORTED_LOCALES;
const zhHansSite = {
  code: 'zh-cn',
  label: '简体中文',
  href: 'https://1panel.cn/',
};
const desktopLocaleMenuItems = [
  ...SUPPORTED_LOCALES.reduce<Array<{ code: string; label: string; href: string; internal: boolean; active: boolean }>>((items, locale) => {
  items.push({
    code: locale,
    label: getLocaleLabel(locale),
    href: locale === DEFAULT_LOCALE ? '/' : `/${locale}/`,
    internal: true,
    active: locale === currentLocale,
  });

  return items;
}, []),
  {
    code: zhHansSite.code,
    label: zhHansSite.label,
    href: zhHansSite.href,
    internal: false,
    active: false,
  },
];
const mobileLocaleMenuItems = desktopLocaleMenuItems.filter((item) => !item.active);
---

<header class="sticky top-0 left-0 right-0 z-[110] bg-dark-200/80 backdrop-blur-md border-b border-gray-200">
  <nav class="container-custom">
    <div 
      class="grid h-16 w-full grid-cols-[auto_1fr] items-center gap-4 lg:h-20 lg:grid-cols-[auto_1fr_auto] lg:gap-6"
    >
      <!-- Left: Logo -->
      <div class="flex items-center space-x-3 shrink-0 min-w-0">
        <a href={prefix || '/'} class="inline-flex items-center shrink-0">
          <img
            src={logoSrc}
            alt="1Panel Logo"
            class="h-12 w-auto max-h-12 object-contain object-left"
            loading="eager"
            decoding="async"
          />
        </a>
      </div>
      <!-- Center: 主菜单 -->
      <div id="header-center-nav" class="hidden min-w-0 flex-1 items-center justify-center gap-1 lg:flex">
        <a href={`${prefix}/pricing`} target="_blank" class="group relative inline-flex h-10 items-center rounded-full px-4 text-[15px] font-medium text-gray-600 transition-colors duration-200 hover:text-gray-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/30">
          <span>{t(translations, 'header.pricing')}</span>
          <span class="pointer-events-none absolute inset-x-4 bottom-1 h-px origin-left scale-x-0 bg-gray-900 transition-transform duration-200 group-hover:scale-x-100 group-focus-visible:scale-x-100"></span>
        </a>
        <a href={prefix ? `${prefix}/blog.html` : '/blog.html'} class="group relative inline-flex h-10 items-center rounded-full px-4 text-[15px] font-medium text-gray-600 transition-colors duration-200 hover:text-gray-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/30">
          <span>{t(translations, 'header.blog')}</span>
          <span class="pointer-events-none absolute inset-x-4 bottom-1 h-px origin-left scale-x-0 bg-gray-900 transition-transform duration-200 group-hover:scale-x-100 group-focus-visible:scale-x-100"></span>
        </a>
        <a href="https://1panel.pro/docs/" target="_blank" class="group relative inline-flex h-10 items-center rounded-full px-4 text-[15px] font-medium text-gray-600 transition-colors duration-200 hover:text-gray-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/30">
          <span>{t(translations, 'header.docs')}</span>
          <span class="pointer-events-none absolute inset-x-4 bottom-1 h-px origin-left scale-x-0 bg-gray-900 transition-transform duration-200 group-hover:scale-x-100 group-focus-visible:scale-x-100"></span>
        </a>
      </div>
      <!-- Right: 语言切换及按钮 -->
      <div id="header-right-actions" class="hidden shrink-0 items-center justify-end gap-3 lg:flex">
        {(
          <div class="relative" id="lang-switcher-desktop">
            <button type="button" data-lang-trigger class="inline-flex h-10 items-center gap-1 rounded-full px-4 text-[15px] font-medium text-gray-600 transition-colors duration-200 hover:text-gray-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/25" aria-haspopup="true" aria-expanded="false">
              <span>{getLocaleLabel(currentLocale)}</span>
              <Icon name="tabler:chevron-down" data-lang-chevron class="h-4 w-4 shrink-0 text-gray-400 transition-transform duration-200" />
            </button>
            <div data-lang-menu class="pointer-events-none invisible fixed z-[9999]" style="top: 0; left: 0;">
              <div class="w-48 overflow-hidden rounded-2xl border border-gray-200 bg-white p-1.5 shadow-[0_22px_56px_-28px_rgba(15,23,42,0.3)]" role="menu">
                {desktopLocaleMenuItems.map((item) => (
                  <a href={item.href} {...(item.internal ? { 'data-locale-link': true, 'data-locale': item.code } : { target: '_blank', rel: 'noopener noreferrer' })} class="flex items-center justify-between rounded-xl px-3 py-2.5 text-[15px] font-medium text-gray-700 transition-colors duration-150 hover:bg-gray-50 hover:text-gray-900 focus-visible:bg-gray-50 focus-visible:text-gray-900 focus-visible:outline-none" role="menuitem">
                    <span>{item.label}</span>
                    {item.active && <Icon name="tabler:check" class="h-4 w-4 shrink-0 text-gray-700" />}
                  </a>
                ))}
              </div>
            </div>
          </div>
        )}
        <a href="https://demo.1panel.pro/" target="_blank" class="try-demo-button btn-secondary inline-flex h-11 min-w-[116px] items-center justify-center gap-2 whitespace-nowrap rounded-full !px-4 !py-2.5 text-sm !font-medium !shadow-none transition-all duration-200 hover:!scale-100 hover:!bg-white hover:!shadow-[0_16px_40px_-32px_rgba(15,23,42,0.7)]">
          <Icon name="carbon:demo" class="h-5 w-5" />
          {t(translations, 'header.demo')}
        </a>
        <a href="mailto:hi@lxware.hk?subject=1Panel Pro: 30-Day Free Trial Request" target="_blank" class="free-trial-button btn-primary inline-flex h-11 min-w-[132px] items-center justify-center gap-2 whitespace-nowrap rounded-full !px-4 !py-2.5 text-sm !font-medium shadow-[0_18px_44px_-28px_rgba(0,94,235,0.65)] transition-all duration-200 hover:!scale-100 hover:shadow-[0_24px_48px_-28px_rgba(0,94,235,0.45)]">
          <Icon name="carbon:email" class="h-5 w-5" />
          {t(translations, 'header.freeTrial')}
        </a>
      </div>
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="justify-self-end rounded-full p-2 text-gray-700 transition-colors hover:text-gray-900 lg:hidden" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
    <!-- Mobile Navigation -->
    <div
      id="mobile-menu"
      class="lg:hidden fixed inset-0 z-[99] bg-white transition-all duration-300 overflow-y-auto hidden"
      style="touch-action:manipulation; min-height: 100vh; height: 100vh;"
    >
      <div class="relative w-full max-w-[440px] mx-auto flex flex-col min-h-screen px-5 pt-8 pb-8"
           style="height: 100vh; min-height: 100vh; box-sizing: border-box;">
        <button
          type="button"
          class="absolute top-3 right-3 rounded-full p-3 bg-gray-100 hover:bg-gray-200 transition"
          aria-label="Close menu"
          onclick="document.getElementById('mobile-menu').classList.add('hidden')"
        >
          <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

        <nav class="flex flex-col gap-1 mt-2">
          <a
            href={`${prefix}/pricing`}
            target="_blank"
            class="block rounded-lg px-4 py-3 text-base font-medium text-gray-900 hover:bg-gray-100 active:bg-gray-200 transition"
          >
            {t(translations, 'header.pricing')}
          </a>
          <a
            href={prefix ? `${prefix}/blog.html` : '/blog.html'}
            class="block rounded-lg px-4 py-3 text-base font-medium text-gray-900 hover:bg-gray-100 active:bg-gray-200 transition"
          >
            {t(translations, 'header.blog')}
          </a>
          <a
            href="https://github.com/1Panel-dev/1Panel/discussions"
            target="_blank"
            class="block rounded-lg px-4 py-3 text-base font-medium text-gray-900 hover:bg-gray-100 active:bg-gray-200 transition"
          >
            {t(translations, 'header.discussions')}
          </a>
          <a
            href="https://1panel.pro/docs/"
            target="_blank"
            class="block rounded-lg px-4 py-3 text-base font-medium text-gray-900 hover:bg-gray-100 active:bg-gray-200 transition"
          >
            {t(translations, 'header.docs')}
          </a>
        </nav>

        {(
          <div class="pt-5 border-t border-gray-100 mt-5">
            <div class="mb-2 text-gray-500 text-[15px] font-medium flex items-center gap-1">
              <Icon name="carbon:earth" class="w-4 h-4" />
              {getLocaleLabel(currentLocale)}
            </div>
            <div class="flex flex-wrap gap-2">
              {mobileLocaleMenuItems.map((item) => (
                <a
                  href={item.href}
                  {...(item.internal ? { 'data-locale-link': true, 'data-locale': item.code } : { target: '_blank', rel: 'noopener noreferrer' })}
                  class="py-1 px-3 text-[15px] text-blue-600 font-medium bg-blue-50 rounded hover:bg-blue-100 transition"
                  style="min-width:72px;text-align:center;"
                >
                  {item.label}
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="flex flex-col gap-3 pt-8 mt-auto">
          <a
            href="https://demo.1panel.pro/"
            target="_blank"
            class="btn-secondary text-base px-4 py-3 rounded-lg flex items-center justify-center font-semibold"
          >
            <Icon name="carbon:demo" class="w-5 h-5 mr-2 text-blue-700" />
            {t(translations, 'header.demo')}
          </a>
          <a
            href="mailto:hi@lxware.hk"
            target="_blank"
            class="btn-primary text-base px-4 py-3 rounded-lg flex items-center justify-center font-semibold"
          >
            <Icon name="carbon:email" class="w-5 h-5 mr-2" />
            {t(translations, 'header.freeTrial')}
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script define:vars={{ supportedLocaleCodes }}>
  // Mobile menu toggle
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const desktopLangSwitcher = document.getElementById('lang-switcher-desktop');
    const desktopLangTrigger = desktopLangSwitcher?.querySelector('[data-lang-trigger]');
    const desktopLangMenu = desktopLangSwitcher?.querySelector('[data-lang-menu]');
    const desktopLangChevron = desktopLangSwitcher?.querySelector('[data-lang-chevron]');

    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });

      // Close mobile menu when clicking on a link
      const mobileLinks = mobileMenu.querySelectorAll('a');
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
        });
      });
    }

    if (desktopLangSwitcher && desktopLangTrigger) {
      if (desktopLangMenu instanceof HTMLElement && desktopLangMenu.parentElement !== document.body) {
        document.body.appendChild(desktopLangMenu);
      }

      let closeTimer = null;

      const updateLangMenuPosition = () => {
        if (!(desktopLangTrigger instanceof HTMLElement) || !(desktopLangMenu instanceof HTMLElement)) return;

        const rect = desktopLangTrigger.getBoundingClientRect();
        const menuWidth = desktopLangMenu.offsetWidth || 224;
        const viewportPadding = 16;
        const left = Math.min(
          Math.max(viewportPadding, rect.right - menuWidth),
          window.innerWidth - menuWidth - viewportPadding
        );
        const top = rect.bottom + 8;

        desktopLangMenu.style.left = `${left}px`;
        desktopLangMenu.style.top = `${top}px`;
      };

      const setExpanded = (expanded) => {
        desktopLangTrigger.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        if (!(desktopLangMenu instanceof HTMLElement)) return;

        desktopLangMenu.classList.toggle('pointer-events-none', !expanded);
        desktopLangMenu.classList.toggle('invisible', !expanded);
        desktopLangMenu.classList.toggle('pointer-events-auto', expanded);
        desktopLangMenu.classList.toggle('visible', expanded);

        if (desktopLangChevron instanceof HTMLElement) {
          desktopLangChevron.classList.toggle('rotate-180', expanded);
        }
      };

      const clearCloseTimer = () => {
        if (closeTimer) {
          window.clearTimeout(closeTimer);
          closeTimer = null;
        }
      };

      const openMenu = () => {
        clearCloseTimer();
        updateLangMenuPosition();
        setExpanded(true);
      };

      const closeMenu = () => {
        clearCloseTimer();
        setExpanded(false);
      };

      const scheduleClose = () => {
        clearCloseTimer();
        closeTimer = window.setTimeout(() => {
          closeMenu();
        }, 80);
      };

      desktopLangSwitcher.addEventListener('mouseenter', openMenu);
      desktopLangSwitcher.addEventListener('mouseleave', scheduleClose);
      desktopLangSwitcher.addEventListener('focusin', openMenu);
      desktopLangSwitcher.addEventListener('focusout', (event) => {
        const nextTarget = event.relatedTarget;
        if (nextTarget instanceof Node && (desktopLangSwitcher.contains(nextTarget) || (desktopLangMenu instanceof HTMLElement && desktopLangMenu.contains(nextTarget)))) return;
        scheduleClose();
      });
      desktopLangSwitcher.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeMenu();
          const activeElement = document.activeElement;
          if (activeElement instanceof HTMLElement && desktopLangSwitcher.contains(activeElement)) {
            activeElement.blur();
          }
        }
      });
      desktopLangTrigger.addEventListener('click', (event) => {
        event.preventDefault();
        const isExpanded = desktopLangTrigger.getAttribute('aria-expanded') === 'true';
        if (isExpanded) {
          closeMenu();
        } else {
          openMenu();
        }
      });
      if (desktopLangMenu instanceof HTMLElement) {
        desktopLangMenu.addEventListener('mouseenter', openMenu);
        desktopLangMenu.addEventListener('mouseleave', scheduleClose);
        desktopLangMenu.addEventListener('focusout', (event) => {
          const nextTarget = event.relatedTarget;
          if (nextTarget instanceof Node && (desktopLangMenu.contains(nextTarget) || desktopLangSwitcher.contains(nextTarget))) return;
          scheduleClose();
        });
        desktopLangMenu.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            closeMenu();
            if (desktopLangTrigger instanceof HTMLElement) {
              desktopLangTrigger.focus();
            }
          }
        });
      }
      document.addEventListener('pointerdown', (event) => {
        const target = event.target;
        if (!(target instanceof Node)) return;
        if (desktopLangSwitcher.contains(target)) return;
        if (desktopLangMenu instanceof HTMLElement && desktopLangMenu.contains(target)) return;
        closeMenu();
      });
      window.addEventListener('resize', updateLangMenuPosition);
      window.addEventListener('scroll', () => {
        if (desktopLangTrigger.getAttribute('aria-expanded') === 'true') {
          updateLangMenuPosition();
        }
      }, true);
    }

    // Keep current page when switching language:
    // /foo/bar -> /ja/foo/bar, /ja/foo/bar -> /foo/bar
    const localeLinks = document.querySelectorAll('[data-locale-link]');
    const supported = supportedLocaleCodes;
    const currentPath = window.location.pathname || '/';
    const segments = currentPath.replace(/^\/+|\/+$/g, '').split('/').filter(Boolean);
    const hasLocalePrefix = segments.length > 0 && supported.includes(segments[0]);
    const rest = hasLocalePrefix ? segments.slice(1).join('/') : segments.join('/');
    const suffix = rest ? `/${rest}` : '/';

    localeLinks.forEach((link) => {
      const targetLocale = link.getAttribute('data-locale');
      if (!targetLocale) return;
      const href = targetLocale === 'en' ? (suffix === '/' ? '/' : suffix) : `/${targetLocale}${suffix === '/' ? '/' : suffix}`;
      link.setAttribute('href', href);
    });
  });
</script>

<style>
  @media (max-width: 1023px) {
    #header-center-nav,
    #header-right-actions {
      display: none !important;
    }
  }
</style>
