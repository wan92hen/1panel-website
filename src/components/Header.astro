---
// Header component for 1Panel website
import { Icon } from 'astro-icon/components'
import { SUPPORTED_LOCALES, getLocaleLabel } from '../i18n/config';
import { t, getTranslations } from '../i18n/utils';
import type { TranslationDict } from '../i18n/utils';
import { publicAsset } from '../lib/asset';

interface Props {
  lang?: string;
  basePath?: string;
  translations?: TranslationDict;
}

const { lang, basePath = './', translations: rawTranslations } = Astro.props;
const logoSrc = publicAsset('images/logo-blue.png');
const translations = rawTranslations && Object.keys(rawTranslations).length > 0 ? rawTranslations : getTranslations('en');
const prefix = lang ? `/${lang}` : '';
---

<header class="sticky top-0 left-0 right-0 z-50 bg-dark-200/80 backdrop-blur-md border-b border-gray-200">
  <nav class="container-custom">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <div class="flex items-center space-x-3">
        <a href={prefix || '/'} class="inline-flex items-center shrink-0">
          <img
            src={logoSrc}
            alt="1Panel Logo"
            class="h-12 w-auto max-h-12 object-contain object-left"
            loading="eager"
            decoding="async"
          />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center space-x-8">
        <a href={`${prefix}/pricing`} target="_blank" class="relative text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 group">
          {t(translations, 'header.pricing')}
        </a>
        <a href={prefix ? `${prefix}/blogs.html` : '/blogs.html'} class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300">
          {t(translations, 'header.blog')}
        </a>
        <a href="https://docs.1panel.pro/" target="_blank" class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300">{t(translations, 'header.docs')}</a>
        <a href="https://github.com/1Panel-dev/1Panel/discussions" target="_blank" class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300">{t(translations, 'header.discussions')}</a>
        <!-- Language Switcher -->
        {lang && (
          <div class="relative group" id="lang-switcher-desktop">
            <button type="button" class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 inline-flex items-center" aria-haspopup="true" aria-expanded="false">
              <Icon name="carbon:earth" class="w-5 h-5 mr-1" />
              <span>{getLocaleLabel(lang)}</span>
            </button>
            <div class="absolute top-full right-0 py-1 w-40 bg-white rounded-lg shadow-lg border border-gray-200 hidden group-hover:block z-[90]" role="menu">
              {SUPPORTED_LOCALES.filter((l) => l !== lang).map((locale) => (
                <a href={`/${locale}/`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">{getLocaleLabel(locale)}</a>
              ))}
            </div>
          </div>
        )}
        <div class="flex items-center space-x-4">
          <a href="https://demo.1panel.pro/" target="_blank" class="btn-secondary text-sm inline-flex items-center">
            <Icon name="carbon:demo" class="w-5 h-5 mr-2" />
            {t(translations, 'header.demo')}
          </a>
          <a href="https://github.com/1Panel-dev/1Panel" target="_blank" class="btn-primary text-sm inline-flex items-center">
            <Icon name="carbon:logo-github" class="w-5 h-5 mr-2" />
            {t(translations, 'header.github')}
          </a>
        </div>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-gray-700 hover:text-gray-900">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="lg:hidden hidden pb-4">
      <div class="flex flex-col space-y-4">
        <a href={`${prefix}/pricing`} target="_blank" class="relative text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 group">
          {t(translations, 'header.pricing')}
        </a>
        <a href={prefix ? `${prefix}/blogs.html` : '/blogs.html'} class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300">
          {t(translations, 'header.blog')}
        </a>
        <a href="https://github.com/1Panel-dev/1Panel/discussions" target="_blank" class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300">{t(translations, 'header.discussions')}</a>
        <a href="https://1panel.pro/docs" target="_blank" class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300">{t(translations, 'header.docs')}</a>
        {lang && (
          <div class="pt-2">
            <span class="text-gray-500 text-sm block mb-2">{getLocaleLabel(lang)}</span>
            <div class="flex flex-wrap gap-2">
              {SUPPORTED_LOCALES.filter((l) => l !== lang).map((locale) => (
                <a href={`/${locale}/`} class="text-sm text-1panel hover:underline">{getLocaleLabel(locale)}</a>
              ))}
            </div>
          </div>
        )}
        <div class="flex flex-col space-y-3 pt-4">
          <a href="https://demo.1panel.pro/" target="_blank" class="btn-secondary text-sm text-center">
            <Icon name="carbon:demo" class="w-5 h-5 mr-3 text-gray-700" />
            {t(translations, 'header.demo')}
          </a>
          <a href="https://github.com/1Panel-dev/1Panel" target="_blank" class="btn-primary text-sm text-center">
            {t(translations, 'header.github')}
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });

      // Close mobile menu when clicking on a link
      const mobileLinks = mobileMenu.querySelectorAll('a');
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
        });
      });
    }
  });
</script>
