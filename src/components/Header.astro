---
// Header component for 1Panel website
import { Icon } from 'astro-icon/components'
import { SUPPORTED_LOCALES, getLocaleLabel } from '../i18n/config';
import { t, getTranslations } from '../i18n/utils';
import type { TranslationDict } from '../i18n/utils';
import { publicAsset } from '../lib/asset';

interface Props {
  lang?: string;
  basePath?: string;
  translations?: TranslationDict;
}

const { lang, basePath = './', translations: rawTranslations } = Astro.props;
const logoSrc = publicAsset('images/logo-blue.png');
const translations = rawTranslations && Object.keys(rawTranslations).length > 0 ? rawTranslations : getTranslations('en');
const prefix = lang ? `/${lang}` : '';
---

<header class="sticky top-0 left-0 right-0 z-50 bg-dark-200/80 backdrop-blur-md border-b border-gray-200">
  <nav class="container-custom">
    <div 
      class="grid grid-cols-3 items-center h-16 lg:h-20 w-full"
    >
      <!-- Left: Logo -->
      <div class="flex items-center space-x-3 shrink-0 min-w-0">
        <a href={prefix || '/'} class="inline-flex items-center shrink-0">
          <img
            src={logoSrc}
            alt="1Panel Logo"
            class="h-12 w-auto max-h-12 object-contain object-left"
            loading="eager"
            decoding="async"
          />
        </a>
      </div>
      <!-- Center: 主菜单 -->
      <div id="header-center-nav" class="hidden lg:flex items-center justify-center space-x-8 min-w-0 flex-1">
        <a href={`${prefix}/pricing`} target="_blank" class="relative text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 group">
          {t(translations, 'header.pricing')}
        </a>
        <a href={prefix ? `${prefix}/blogs.html` : '/blogs.html'} class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300">
          {t(translations, 'header.blog')}
        </a>
        <a href="https://docs.1panel.pro/" target="_blank" class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300">
          {t(translations, 'header.docs')}
        </a>
      </div>
      <!-- Right: 语言切换及按钮 -->
      <div id="header-right-actions" class="hidden lg:flex items-center space-x-4 shrink-0 justify-end">
        {lang && (
          <div class="relative group" id="lang-switcher-desktop">
            <button type="button" class="text-gray-700 hover:text-gray-900 hover:font-bold transition-colors duration-300 inline-flex items-center" aria-haspopup="true" aria-expanded="false">
              <Icon name="carbon:earth" class="w-5 h-5 mr-1" />
              <span>{getLocaleLabel(lang)}</span>
            </button>
            <div class="absolute top-full right-0 py-1 w-40 bg-white rounded-lg shadow-lg border border-gray-200 hidden group-hover:block z-[90]" role="menu">
              {SUPPORTED_LOCALES.filter((l) => l !== lang).map((locale) => (
                <a href={`/${locale}/`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem">{getLocaleLabel(locale)}</a>
              ))}
            </div>
          </div>
        )}
        <a href="https://demo.1panel.pro/" target="_blank" class="btn-secondary text-sm inline-flex items-center">
          <Icon name="carbon:demo" class="w-5 h-5 mr-2" />
          {t(translations, 'header.demo')}
        </a>
        <a href="mailto:hi@lxware.hk?subject=1Panel Pro: 30-Day Free Trial Request" target="_blank" class="btn-primary text-sm inline-flex items-center">
          <Icon name="carbon:email" class="w-5 h-5 mr-2" />
          {t(translations, 'header.freeTrial')}
        </a>
      </div>
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-gray-700 hover:text-gray-900 shrink-0" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
    <!-- Mobile Navigation -->
    <div
      id="mobile-menu"
      class="lg:hidden fixed inset-0 z-[99] bg-white transition-all duration-300 overflow-y-auto hidden"
      style="touch-action:manipulation; min-height: 100vh; height: 100vh;"
    >
      <div class="relative w-full max-w-[440px] mx-auto flex flex-col min-h-screen px-5 pt-8 pb-8"
           style="height: 100vh; min-height: 100vh; box-sizing: border-box;">
        <button
          type="button"
          class="absolute top-3 right-3 rounded-full p-3 bg-gray-100 hover:bg-gray-200 transition"
          aria-label="Close menu"
          onclick="document.getElementById('mobile-menu').classList.add('hidden')"
        >
          <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>

        <nav class="flex flex-col gap-1 mt-2">
          <a
            href={`${prefix}/pricing`}
            target="_blank"
            class="block rounded-lg px-4 py-3 text-base font-medium text-gray-900 hover:bg-gray-100 active:bg-gray-200 transition"
          >
            {t(translations, 'header.pricing')}
          </a>
          <a
            href={prefix ? `${prefix}/blogs.html` : '/blogs.html'}
            class="block rounded-lg px-4 py-3 text-base font-medium text-gray-900 hover:bg-gray-100 active:bg-gray-200 transition"
          >
            {t(translations, 'header.blog')}
          </a>
          <a
            href="https://github.com/1Panel-dev/1Panel/discussions"
            target="_blank"
            class="block rounded-lg px-4 py-3 text-base font-medium text-gray-900 hover:bg-gray-100 active:bg-gray-200 transition"
          >
            {t(translations, 'header.discussions')}
          </a>
          <a
            href="https://docs.1panel.pro/"
            target="_blank"
            class="block rounded-lg px-4 py-3 text-base font-medium text-gray-900 hover:bg-gray-100 active:bg-gray-200 transition"
          >
            {t(translations, 'header.docs')}
          </a>
        </nav>

        {lang && (
          <div class="pt-5 border-t border-gray-100 mt-5">
            <div class="mb-2 text-gray-500 text-[15px] font-medium flex items-center gap-1">
              <Icon name="carbon:earth" class="w-4 h-4" />
              {getLocaleLabel(lang)}
            </div>
            <div class="flex flex-wrap gap-2">
              {SUPPORTED_LOCALES.filter((l) => l !== lang).map((locale) => (
                <a
                  href={`/${locale}/`}
                  class="py-1 px-3 text-[15px] text-blue-600 font-medium bg-blue-50 rounded hover:bg-blue-100 transition"
                  style="min-width:72px;text-align:center;"
                >
                  {getLocaleLabel(locale)}
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="flex flex-col gap-3 pt-8 mt-auto">
          <a
            href="https://demo.1panel.pro/"
            target="_blank"
            class="btn-secondary text-base px-4 py-3 rounded-lg flex items-center justify-center font-semibold"
          >
            <Icon name="carbon:demo" class="w-5 h-5 mr-2 text-blue-700" />
            {t(translations, 'header.demo')}
          </a>
          <a
            href="mailto:hi@lxware.hk"
            target="_blank"
            class="btn-primary text-base px-4 py-3 rounded-lg flex items-center justify-center font-semibold"
          >
            <Icon name="carbon:email" class="w-5 h-5 mr-2" />
            {t(translations, 'header.freeTrial')}
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });

      // Close mobile menu when clicking on a link
      const mobileLinks = mobileMenu.querySelectorAll('a');
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
        });
      });
    }
  });
</script>

<style>
  @media (max-width: 1023px) {
    #header-center-nav,
    #header-right-actions {
      display: none !important;
    }
  }
</style>
