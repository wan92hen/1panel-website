---
import { Icon } from "astro-icon/components";

export interface Props {
  variant: "GB10" | "B70";
  partner: string;
  productImage: string;
  productImageAlt: string;
  hardware: string;
  hardwareDetail: string;
}

const {
  variant,
  partner,
  productImage,
  productImageAlt,
  hardware,
  hardwareDetail,
} = Astro.props;

const title = `AI Coding 一体机（${variant}版）`;
const price = variant === "B70" ? "￥11.9万" : "￥9.9万";
const strengths = [
  {
    title: "安全",
    description: "纯内网运行，确保数据不出域",
    icon: "carbon:security",
  },
  {
    title: "高效",
    description: "支持 10-20 人团队的编程开发需求，实现 Token 自由",
    icon: "carbon:flash",
  },
  {
    title: "省心",
    description: "图形化界面，非技术成员也能高效运维",
    icon: "carbon:user-follow",
  },
];

const stackItems = [
  {
    label: "硬",
    title: hardware,
    description: hardwareDetail,
  },
  {
    label: "模",
    title: "Qwen 3.6 27B",
    description: "接近 Claude 4.5 的编程能力，生成界面美观、功能完备复杂需求一次到位",
  },
  {
    label: "管",
    title: "1Panel 企业版",
    description: "支持 vLLM 管理、纯离线管理、多用户管理和 AI 代理网关",
  },
  {
    label: "链",
    title: "1Panel 应用商店",
    description:
      "提供完善的开源 DevOps 工具链，涵盖项目管理、代码托管、制品库管理、持续集成和持续测试",
  },
];

const benchmarkHighlights = [
  { label: "SWE-bench Verified", value: "77.2" },
  { label: "SWE-bench Pro", value: "53.5" },
  { label: "Terminal-Bench 2.0", value: "59.3" },
  { label: "LiveCodeBench v6", value: "83.9" },
];

const benchmarkRows = [
  {
    metric: "SWE-bench Verified",
    qwen35: "76.2",
    claude: "80.9",
    qwen36: "77.2",
  },
  {
    metric: "SWE-bench Pro",
    qwen35: "50.9",
    claude: "57.1",
    qwen36: "53.5",
  },
  {
    metric: "SWE-bench Multilingual",
    qwen35: "69.3",
    claude: "77.5",
    qwen36: "71.3",
  },
  {
    metric: "Terminal-Bench 2.0",
    qwen35: "52.5",
    claude: "59.3",
    qwen36: "59.3",
  },
  {
    metric: "SkillsBench Avg5",
    qwen35: "30.0",
    claude: "45.3",
    qwen36: "48.2",
  },
  {
    metric: "QwenWebBench",
    qwen35: "1186",
    claude: "1536",
    qwen36: "1487",
  },
  {
    metric: "NL2Repo",
    qwen35: "32.2",
    claude: "43.2",
    qwen36: "36.2",
  },
  {
    metric: "Claw-Eval Avg",
    qwen35: "70.7",
    claude: "76.6",
    qwen36: "72.4",
  },
  {
    metric: "Claw-Eval Pass^3",
    qwen35: "48.1",
    claude: "59.6",
    qwen36: "60.6",
  },
  {
    metric: "QwenClawBench",
    qwen35: "51.8",
    claude: "52.3",
    qwen36: "53.4",
  },
];
---

<main class="relative z-10">
  <section class="relative overflow-hidden bg-gray-50 min-h-[80vh] flex items-center">
    <div class="relative z-10 container-custom py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="text-center lg:text-left">
          <div class="fade-in-up inline-flex items-center px-4 py-2 mb-6 bg-blue-100 text-blue-800 rounded-full text-sm font-medium">
            飞致云匠心出品
          </div>
          <h1 class="fade-in-up text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-8" style="animation-delay: 0.2s;">
            <span class="block text-gray-800 mb-4">AI 编程一体机</span>
            <span class="block text-1panel-gradient mb-2 leading-light">为团队部署而生</span>
          </h1>
          <p class="fade-in-up text-xl sm:text-2xl text-gray-500 mb-10 leading-relaxed" style="animation-delay: 0.4s;">
            轻松支持 10-20 个开发人员的 AI 编程开发，彻底告别 Token 焦虑
          </p>
          <div class="fade-in-up flex flex-col sm:flex-row gap-4 justify-center lg:justify-start" style="animation-delay: 0.5s;">
            <a href="#contact" class="btn-primary text-lg px-8 py-4 inline-flex items-center justify-center">
              微信扫码咨询
            </a>
            <a href="#capability" class="btn-secondary text-lg px-8 py-4 inline-flex items-center justify-center">
              查看编程能力
            </a>
          </div>
        </div>

        <div class="fade-in-up flex justify-center lg:justify-end" style="animation-delay: 0.3s;">
          <div class="w-full max-w-lg">
            <img
              src={productImage}
              alt={productImageAlt}
              class="w-full h-auto"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white border-t border-gray-100">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="section-title text-4xl lg:text-5xl font-bold text-gray-800 mb-6">
          内网环境下的<span class="text-1panel-gradient">编程效率革命者</span>
        </h2>
        <p class="section-subtitle text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
          面向政府/军工内网开发、金融级安全研发、能源/制造涉密项目、企业核心代码开发等需纯内网隔离的场景。
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {
          strengths.map((item) => (
            <div class="rounded-2xl bg-gray-100/80 border border-gray-100 p-6 lg:p-8 transition-all duration-200 hover:border-indigo-100 hover:shadow-md flex flex-col">
              <div class="flex items-center gap-3 mb-4">
                <span aria-hidden="true" class="flex-shrink-0 w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600 font-bold text-sm">✓</span>
                <h3 class="text-lg font-bold text-gray-900">{item.title}</h3>
              </div>
              <p class="text-gray-600 leading-relaxed flex-1">{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-padding bg-gradient-to-b from-gray-50 to-white">
    <div class="container-custom">
      <div class="rounded-3xl bg-white border border-gray-100 shadow-sm shadow-gray-200/60 overflow-hidden">
        <div class="px-6 sm:px-10 pt-10 pb-8 text-center border-b border-gray-100">
          <h2 class="section-title text-4xl lg:text-5xl font-bold text-gray-800 mb-6">
            软硬协同·<span class="text-1panel-gradient">全栈赋能</span>
          </h2>
          <p class="section-subtitle text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
            从算力底座、模型能力到 1Panel 企业版与 DevOps 工具链，一站式满足内网 AI 编程开发需求。
          </p>
        </div>

        <div class="p-6 sm:p-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
          {
            stackItems.map((item) => (
              <div class="rounded-xl bg-gray-50/80 border border-gray-100 p-5 transition-all duration-200 hover:border-indigo-100 hover:shadow-md">
                <div class="w-11 h-11 rounded-lg bg-indigo-50 flex items-center justify-center text-indigo-600 font-bold text-base mb-3">
                  {item.label}
                </div>
                <h3 class="text-base font-bold text-gray-900 mb-1.5">{item.title}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="contact" class="section-padding bg-white">
    <div class="container-custom">
      <div class="rounded-2xl border border-gray-100 bg-indigo-50/40 p-8 shadow-lg flex flex-col md:flex-row gap-6 md:gap-0 md:items-center md:justify-center">
        <div class="flex flex-col items-center md:items-end md:pr-12 flex-1 md:max-w-[420px]">
          <div class="mb-5 flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-indigo-50 text-indigo-600">
              <Icon name="carbon:purchase" class="h-6 w-6" />
            </div>
            <h2 class="text-3xl lg:text-4xl font-bold text-gray-900">价格</h2>
          </div>
          <div class="flex flex-wrap items-end justify-center md:justify-end gap-3 mb-5">
            <span class="text-5xl font-bold text-gray-900">{price}</span>
            <span class="pb-2 text-lg text-gray-500">含一年软硬件维保</span>
          </div>
          <p class="text-lg text-gray-600 leading-relaxed text-center md:text-right">
            通过微信扫码咨询，获取 {title} 的详细性能参数与采购信息。
          </p>
        </div>

        <div class="hidden md:block h-36 w-px bg-gray-200 mx-12"></div>

        <div class="flex flex-col items-center flex-1 md:max-w-[320px]">
          <img
            src="/images/wecom-qrcode.png"
            alt="微信扫码咨询"
            class="w-32 h-32 rounded-lg border border-gray-200 shadow-sm bg-white p-2 mb-2"
            loading="lazy"
          />
          <p class="text-base font-semibold text-gray-800 text-center">微信扫码咨询</p>
        </div>
      </div>
    </div>
  </section>

  <section id="capability" class="section-padding bg-white border-t border-gray-100">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="section-title text-4xl lg:text-5xl font-bold text-gray-800 mb-6">编程能力</h2>
        <p class="section-subtitle text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
          Qwen3.6-27B 在多方面领先 Qwen3.5-397B-A17B，接近 Claude 4.5 的水平。
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        {
          benchmarkHighlights.map((item) => (
            <div class="rounded-xl bg-gray-50 border border-gray-100 p-5 text-center">
              <div class="text-3xl font-bold text-1panel mb-2">{item.value}</div>
              <div class="text-sm text-gray-600">{item.label}</div>
            </div>
          ))
        }
      </div>

      <div class="rounded-2xl border border-gray-100 bg-white shadow-sm shadow-gray-200/60 overflow-x-auto">
        <table class="min-w-[760px] w-full border-collapse text-left">
          <thead>
            <tr class="bg-gray-50 text-sm text-gray-500">
              <th class="px-5 py-4 font-semibold">Coding Agent</th>
              <th class="px-5 py-4 font-semibold text-center">Qwen3.5-397B-A17B</th>
              <th class="px-5 py-4 font-semibold text-center">Claude 4.5 Opus</th>
              <th class="px-5 py-4 font-semibold text-center text-1panel">Qwen3.6-27B</th>
            </tr>
          </thead>
          <tbody>
            {
              benchmarkRows.map((row) => (
                <tr class="border-t border-gray-100 text-sm text-gray-700">
                  <td class="px-5 py-4 font-medium text-gray-900">{row.metric}</td>
                  <td class="px-5 py-4 text-center">{row.qwen35}</td>
                  <td class="px-5 py-4 text-center">{row.claude}</td>
                  <td class="px-5 py-4 text-center font-semibold text-gray-900">{row.qwen36}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>
</main>
